---
import '../styles/global.css';
import PwaUpdateToast from '../components/PwaUpdateToast.astro';
import CookieBanner from '../components/CookieBanner.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  jsonLd?: Record<string, any>[];
  noindex?: boolean;
}

const {
  title,
  description,
  image: imageProp,
  type = 'website',
  canonical,
  jsonLd = [],
  noindex = false,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const image = imageProp ?? new URL('/og-cover.png', Astro.site).toString();

// Organization JSON-LD globale (identifica il brand su tutte le pagine).
// Le singole pagine possono aggiungerne altri (Article, FAQPage, BreadcrumbList).
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Sherlock — Detective Polizze',
  alternateName: 'Sherlock Polizze',
  url: Astro.site!.toString().replace(/\/$/, ''),
  logo: new URL('/logo-sherlock.png', Astro.site).toString(),
  sameAs: [
    'https://play.google.com/store/apps/details?id=it.sherlock.polizze',
  ],
};

// Token di verifica Search Console per la proprietà www.sherlockpolizze.it.
// Valore pubblico (finisce comunque nel meta HTML) → hardcodato come default.
// La env var PUBLIC_GOOGLE_SITE_VERIFICATION può overridarlo se in futuro
// Google emette un token nuovo (es. cambio proprietà, delega admin).
const SEARCH_CONSOLE_DEFAULT = 'Gt6_Gl8rQWMM0ukWbARFmOcsogYwp3sCt3XAw9D9SCo';
const searchConsoleToken = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION ?? SEARCH_CONSOLE_DEFAULT;

// GA4 gtag.js. Stream "Sherlock Polizze Web" (stream ID 15187336886, property
// 543947575) è associato al Google Tag `G-VVW7CNHTYJ` — lo stesso MID usato dal
// Firebase SDK: Google ha consolidato le due property in un unico Google Tag.
// Il MID legacy G-21MQHMK771 risulta 404 sulla CDN Google Tag Manager e va
// evitato. Il Measurement ID è pubblico by design (finisce nel bundle client),
// quindi hardcodato come default. PUBLIC_GA4_ID può overridarlo se cambia lo stream.
const GA4_ID_DEFAULT = 'G-VVW7CNHTYJ';
const ga4Id = import.meta.env.PUBLIC_GA4_ID ?? GA4_ID_DEFAULT;
// Emesso nell'HTML solo se PROD (esclude astro dev locale). Il check runtime
// sull'hostname esclude i preview deployment di Vercel (*.vercel.app).
const enableGtag = import.meta.env.PROD;

// Firebase Analytics — caricato solo se le env vars PUBLIC_FIREBASE_* sono presenti.
// Quando l'utente registra l'app Web su Firebase Console (project sherlock-6f88c)
// e copia il config in Vercel env vars, l'analytics si attiva al prossimo deploy.
const firebaseConfig = import.meta.env.PUBLIC_FIREBASE_API_KEY ? {
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
  storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
  appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
  measurementId: import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID,
} : null;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'} />

  {/* Search Console: placeholder — imposta PUBLIC_GOOGLE_SITE_VERIFICATION su Vercel
      con il token fornito da https://search.google.com/search-console. */}
  {searchConsoleToken && <meta name="google-site-verification" content={searchConsoleToken} />}

  {/* Hreflang: il sito ha un solo set di URL crawlable (italiano). Le altre lingue
      sono UX-only tramite Google Translate widget lato client — Google le tratta
      come traduzioni della stessa risorsa. Dichiariamo self it-IT + x-default per
      evitare che Google inferisca hreflang errati da signals esterni. */}
  <link rel="alternate" hreflang="it-IT" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />
  <!-- PWA: installabilità iOS + Android -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Sherlock" />
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon-180.png" />
  <meta name="theme-color" content="#0f172a" />
  <meta http-equiv="content-language" content="it-IT" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- PWA Apple splash screens -->
  <link rel="apple-touch-startup-image" href="/icons/apple-splash-1290-2796.png" media="(device-width: 645px) and (device-height: 1398px) and (-webkit-device-pixel-ratio: 2)" />
  <link rel="apple-touch-startup-image" href="/icons/apple-splash-1320-2868.png" media="(device-width: 660px) and (device-height: 1434px) and (-webkit-device-pixel-ratio: 2)" />
  <link rel="apple-touch-startup-image" href="/icons/apple-splash-1536-2048.png" media="(device-width: 768px) and (device-height: 1024px) and (-webkit-device-pixel-ratio: 2) and (orientation: portrait)" />
  <link rel="apple-touch-startup-image" href="/icons/apple-splash-1668-2388.png" media="(device-width: 834px) and (device-height: 1194px) and (-webkit-device-pixel-ratio: 2)" />
  <link rel="apple-touch-startup-image" href="/icons/apple-splash-2048-2732.png" media="(device-width: 1024px) and (device-height: 1366px) and (-webkit-device-pixel-ratio: 2) and (orientation: portrait)" />
  <link rel="apple-touch-startup-image" href="/icons/apple-splash-2160-1620.png" media="(device-width: 1080px) and (device-height: 810px) and (-webkit-device-pixel-ratio: 2)" />
  <link rel="apple-touch-startup-image" href="/icons/apple-splash-2360-1640.png" media="(device-width: 1180px) and (device-height: 820px) and (-webkit-device-pixel-ratio: 2)" />
  <link rel="apple-touch-startup-image" href="/icons/apple-splash-2868-1320.png" media="(device-width: 1434px) and (device-height: 660px) and (-webkit-device-pixel-ratio: 2)" />

  <!-- Performance: preconnect a domini di terze parti caricati subito -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://www.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.google-analytics.com" />

  <!-- Google Fonts: caricamento non-blocking per non penalizzare LCP.
       Il CSS viene precaricato come 'style' e applicato quando pronto.
       Fallback <noscript> per browser senza JS o crawler. -->
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="Sherlock" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={image} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="it_IT" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Google Play smart banner -->
  <meta name="google-play-app" content="app-id=it.sherlock.polizze" />
  <link rel="alternate" href="android-app://it.sherlock.polizze/https/www.sherlockpolizze.it/" />

  <!-- Google Translate widget (caricato solo se cookie googtrans presente) -->
  <style is:global>
    .skiptranslate { display: none !important; }
    body { top: 0 !important; }
    font.translated-ltr, font.translated-rtl { background: transparent !important; box-shadow: none !important; }
  </style>
  <script is:inline>
    (function(){
      // Carica il widget solo se l'utente ha scelto una lingua != it
      var c = document.cookie.match(/(?:^|; )googtrans=([^;]*)/);
      if (!c) return;
      var v = decodeURIComponent(c[1]);
      if (!v || v === '/it/it') return;
      window.googleTranslateElementInit = function(){
        new google.translate.TranslateElement({
          pageLanguage: 'it',
          includedLanguages: 'en,es,fr,my,zh-CN',
          layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
          autoDisplay: false,
        }, 'google_translate_element');
      };
      var s = document.createElement('script');
      s.src = '//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
      s.async = true;
      document.head.appendChild(s);
    })();
  </script>

  {/* Organization JSON-LD — presente su tutte le pagine per identificare il brand */}
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

  {jsonLd.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  {enableGtag && (
    <script is:inline define:vars={{ ga4Id }}>
      // Google Ads / GA4 gtag.js con Consent Mode v2.
      // - Attivo solo su www.sherlockpolizze.it (skip preview *.vercel.app).
      // - Consent default DENIED per ad_storage, ad_user_data, ad_personalization,
      //   analytics_storage. Il banner CookieBanner chiama gtag('consent','update')
      //   quando l'utente sceglie; le hit precedenti al consenso sono deposit-only
      //   (pings anonimi ai server Google) grazie a Consent Mode.
      // - transport_type: 'beacon' → i click outbound (Play Store) non perdono l'hit.
      (function () {
        try {
          if (typeof window === 'undefined') return;
          var host = window.location.hostname;
          // Whitelist di hostname produzione. Include il dominio nudo per robustezza.
          var isProdHost = host === 'www.sherlockpolizze.it' || host === 'sherlockpolizze.it';
          if (!isProdHost) return;

          window.dataLayer = window.dataLayer || [];
          function gtag() { window.dataLayer.push(arguments); }
          window.gtag = gtag;

          // Consent Mode v2: default DENIED. wait_for_update ritarda le hit
          // per ~500ms dando tempo al banner (o al replay dell'ultima scelta
          // salvata in localStorage) di aggiornare lo stato.
          gtag('consent', 'default', {
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            analytics_storage: 'denied',
            wait_for_update: 500,
          });

          // Replay scelta precedente (l'utente aveva già acconsentito/rifiutato).
          try {
            var prev = localStorage.getItem('sherlock_gtag_consent');
            if (prev === 'granted' || prev === 'denied') {
              gtag('consent', 'update', {
                ad_storage: prev,
                ad_user_data: prev,
                ad_personalization: prev,
                analytics_storage: prev,
              });
            }
          } catch (e) {}

          // Traffico interno: attivato con ?internal=1 (persiste in localStorage),
          // disattivato con ?internal=0. Setta traffic_type=internal sulla config
          // gtag della sola property Ads (G-21MQHMK771); Firebase (G-VVW7CNHTYJ)
          // resta libero perché è un'altra property e i suoi eventi legacy non
          // devono essere filtrati come "internal" da questa configurazione.
          // Su GA4: Admin → Data Streams → Web → Configure tag settings →
          // Define internal traffic; poi Admin → Data Filters → Exclude Internal
          // Traffic → State: Active.
          var isInternal = false;
          try {
            var qsUrl = new URL(window.location.href);
            var flag = qsUrl.searchParams.get('internal');
            if (flag === '1') {
              localStorage.setItem('sherlock_internal', '1');
              isInternal = true;
              // Log solo la prima attivazione per feedback all'utente-owner.
              try { console.info('[sherlock] Traffico interno attivato per questo browser.'); } catch (e) {}
            } else if (flag === '0') {
              localStorage.removeItem('sherlock_internal');
              try { console.info('[sherlock] Traffico interno disattivato per questo browser.'); } catch (e) {}
            } else {
              isInternal = localStorage.getItem('sherlock_internal') === '1';
            }
          } catch (e) {}

          gtag('js', new Date());
          var gtagConfigParams = {
            transport_type: 'beacon',
            anonymize_ip: true,
            send_page_view: true,
          };
          if (isInternal) gtagConfigParams.traffic_type = 'internal';
          gtag('config', ga4Id, gtagConfigParams);

          // Carica gtag.js
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(ga4Id);
          document.head.appendChild(s);

          // Deduce cta_position dal contesto DOM.
          function ctaPosition(el) {
            if (!el || !el.closest) return 'body';
            var marked = el.closest('[data-cta-position]');
            if (marked) return marked.getAttribute('data-cta-position') || 'body';
            if (el.closest('header')) return 'header';
            if (el.closest('footer')) return 'footer';
            var section = el.closest('section');
            if (section) {
              var firstSection = document.querySelector('main section');
              if (section === firstSection) return 'hero';
            }
            return 'body';
          }

          // Helper globale per emissione manuale (pagine specifiche possono chiamarlo).
          // NOTA: NON usiamo send_to per isolare alla property Ads. Osservato in produzione:
          // se il container gtag di G-21MQHMK771 non è ancora servito dalla CDN Google
          // (property nuova → risposta 503 su gtag/js?id=...), send_to fa scartare l'evento
          // invece di routarlo. Meglio la cross-contamination con Firebase (nomi custom
          // click_* sono comunque distinti dai nomi legacy Firebase play_store_click ecc.).
          window.sherlockGtag = function (name, params) {
            if (typeof window.gtag !== 'function') return;
            var base = { page_location: window.location.href };
            var merged = Object.assign(base, params || {});
            window.gtag('event', name, merged);
          };

          // Recupera il vero GA4 client_id + session_id dalla sessione gtag corrente,
          // da trasmettere al backend nelle richieste che possono emettere eventi GA4
          // server-side (analizza, capture-order, attiva-pro). Ritorna sempre un
          // oggetto con `consent` sanificato — se analytics_storage è denied, clientId
          // e sessionId restano undefined e il server-side non emetterà eventi.
          //
          // API: `await window.sherlockGetGA4Context()` → { clientId?, sessionId?, consent }
          window.sherlockGetGA4Context = function () {
            return new Promise(function (resolve) {
              var prev = null;
              try { prev = localStorage.getItem('sherlock_gtag_consent'); } catch (e) {}
              var granted = prev === 'granted';
              var consent = {
                analyticsStorage: granted ? 'granted' : 'denied',
                adStorage: granted ? 'granted' : 'denied',
                adUserData: granted ? 'granted' : 'denied',
                adPersonalization: granted ? 'granted' : 'denied',
              };
              if (!granted || typeof window.gtag !== 'function') {
                resolve({ consent: consent });
                return;
              }
              var got = { clientId: undefined, sessionId: undefined };
              var pending = 2;
              var settled = false;
              var finish = function () {
                if (settled) return;
                settled = true;
                resolve({
                  clientId: got.clientId,
                  sessionId: got.sessionId,
                  consent: consent,
                });
              };
              var step = function () { pending -= 1; if (pending === 0) finish(); };
              // Safety-net: se gtag non chiama i callback entro 500ms, procedi con
              // quello che hai. Impedisce che l'utente aspetti Analytics per
              // navigare (l'analisi/checkout non deve mai bloccarsi sul tracking).
              setTimeout(finish, 500);
              try {
                window.gtag('get', ga4Id, 'client_id', function (cid) {
                  if (typeof cid === 'string' && cid) got.clientId = cid;
                  step();
                });
              } catch (e) { step(); }
              try {
                window.gtag('get', ga4Id, 'session_id', function (sid) {
                  if (typeof sid === 'string' || typeof sid === 'number') {
                    got.sessionId = String(sid);
                  }
                  step();
                });
              } catch (e) { step(); }
            });
          };

          // Click delegate per gli eventi di conversione richiesti da Ads.
          // Capture phase (true) → parte prima di qualunque handler bubble del sito.
          document.addEventListener('click', function (e) {
            var a = e.target && e.target.closest && e.target.closest('a[href]');
            if (!a) return;
            var href = a.getAttribute('href') || '';
            var pos = ctaPosition(a);
            var label = (a.textContent || '').trim().slice(0, 60);
            var eventName = null;

            if (href.indexOf('play.google.com/store/apps') !== -1) {
              eventName = 'click_play_store';
            } else if (
              href === '/app' || href === '/app/' ||
              href.indexOf('/app/') === 0 || href.indexOf('/app?') === 0
            ) {
              eventName = 'start_analysis';
            } else if (
              href === '/abbonati' ||
              href === '/abbonati/' ||
              href.indexOf('/abbonamento/') === 0
            ) {
              eventName = 'click_abbonati';
            } else if (
              href === '/reclamo-ivass' || href === '/reclamo-ivass/' ||
              href === '/reclamo-singolo' || href === '/reclamo-singolo/' ||
              href === '/sinistro-respinto' || href === '/sinistro-respinto/' ||
              href === '/arbitro-assicurativo' || href === '/arbitro-assicurativo/' ||
              href.indexOf('/reclamo-singolo/') === 0
            ) {
              eventName = 'contact_or_report';
            }

            if (!eventName) return;

            // Nessun send_to: vedi nota su sherlockGtag sopra (container G-21MQHMK771
            // non ancora servito → send_to fa scartare l'evento).
            var params = {
              page_location: window.location.href,
              cta_position: pos,
              link_label: label,
            };

            // Se il link naviga in una NUOVA tab (target=_blank, ctrl/meta/shift click,
            // middle click), la pagina corrente resta viva → sendBeacon parte tranquillo.
            var target = (a.getAttribute('target') || '').toLowerCase();
            var newTab = target === '_blank' ||
              e.ctrlKey || e.metaKey || e.shiftKey || e.button === 1;

            // Se il link naviga in SAME TAB (start_analysis /app, click_abbonati /abbonati,
            // contact_or_report /reclamo-*), la navigazione parte prima che gtag flushi la hit.
            // preventDefault + event_callback che naviga dopo → race risolta.
            // Safety net a 700ms nel caso gtag non richiami mai il callback (event_timeout
            // di gtag è 2000ms di default: 700ms è un buon compromesso UX / affidabilità).
            var isInternalNav = !newTab && href.charAt(0) === '/' && !href.startsWith('//');

            if (isInternalNav) {
              e.preventDefault();
              var navigated = false;
              var doNav = function () {
                if (navigated) return;
                navigated = true;
                window.location.href = href;
              };
              params.event_callback = doNav;
              params.event_timeout = 500;
              window.gtag('event', eventName, params);
              setTimeout(doNav, 700);
            } else {
              window.gtag('event', eventName, params);
            }
          }, true);

          // Pass Pro nell'header è un link a /abbonati: sarà catturato sopra
          // e riceverà cta_position = 'header' automaticamente. Nessun tag manuale.

          // NOTE: rimosso il track view-based di contact_or_report su
          // /reclamo-singolo/conferma. La pagina di conferma non rappresenta
          // un "reclamo generato/inviato" — è la conferma dell'ACQUISTO della
          // consulenza. Un evento conversione va emesso solo quando la lettera
          // e' stata effettivamente generata (server-side, da /api/lettera
          // dopo risposta AI riuscita), non a page-view (che si triggera
          // anche al refresh e non implica reclamo completato).
        } catch (err) {
          // Nessuna eccezione deve mai bloccare il rendering della pagina.
        }
      })();
    </script>
  )}

  {firebaseConfig && (
    <script is:inline type="module" define:vars={{ cfg: firebaseConfig }}>
      // Firebase Analytics dinamico via ESM CDN — zero peso al bundle.
      // window.sherlockTrack(event_name, params?) usabile da qualsiasi pagina.
      (async () => {
        try {
          const { initializeApp } = await import('https://www.gstatic.com/firebasejs/10.13.0/firebase-app.js');
          const { getAnalytics, logEvent, setUserProperties } = await import('https://www.gstatic.com/firebasejs/10.13.0/firebase-analytics.js');
          const app = initializeApp(cfg);
          const analytics = getAnalytics(app);
          // Esponi un helper globale per gli script di pagina.
          window.sherlockTrack = (name, params) => {
            try { logEvent(analytics, name, params || {}); } catch (e) { /* noop */ }
          };
          window.sherlockSetUser = (props) => {
            try { setUserProperties(analytics, props || {}); } catch (e) { /* noop */ }
          };
          // Auto-track sulla lingua scelta (cookie googtrans) e su click ai link Play Store.
          const c = document.cookie.match(/(?:^|; )googtrans=([^;]*)/);
          if (c) {
            const v = decodeURIComponent(c[1]);
            const m = v.match(/^\/it\/(.+)$/);
            const lang = m ? (m[1] === 'zh-CN' ? 'zh' : m[1]) : 'it';
            window.sherlockSetUser({ ui_language: lang });
          } else {
            window.sherlockSetUser({ ui_language: 'it' });
          }
          // Referral: se l'URL contiene ?ref=SHK-XXXX-XXXX, salva in localStorage
          // (TTL 60 giorni) per propagarlo al checkout. Espone window.sherlockRef().
          (function captureRef() {
            try {
              const p = new URLSearchParams(location.search);
              const r = (p.get('ref') || '').trim().toUpperCase();
              if (/^SHK-[A-Z0-9]{4}-[A-Z0-9]{4}$/.test(r)) {
                const exp = Date.now() + 60 * 24 * 3600 * 1000;
                localStorage.setItem('sherlock_ref', JSON.stringify({ code: r, exp }));
                window.sherlockTrack('ref_link_landed', { code: r });
              }
            } catch (e) {}
          })();
          window.sherlockRef = function () {
            try {
              const raw = localStorage.getItem('sherlock_ref');
              if (!raw) return null;
              const o = JSON.parse(raw);
              if (!o || !o.code || (o.exp && o.exp < Date.now())) {
                localStorage.removeItem('sherlock_ref');
                return null;
              }
              return o.code;
            } catch (e) { return null; }
          };

          // Auto-page-view events per le pagine chiave (un solo evento per
          // pageview iniziale).
          const path = location.pathname;
          if (path === '/abbonati' || path.endsWith('/abbonati')) {
            window.sherlockTrack('pricing_view', { from_path: document.referrer || '' });
          } else if (path.startsWith('/abbonamento/')) {
            const piano = path.split('/abbonamento/')[1]?.split('/')[0] || '';
            window.sherlockTrack('pricing_plan_view', { piano });
          } else if (path === '/app' || path === '/app/' || path.startsWith('/app/')) {
            window.sherlockTrack('app_view', { from_path: document.referrer || '' });
          } else if (path.startsWith('/guide/')) {
            const slug = path.replace('/guide/', '').replace(/\/$/, '');
            window.sherlockTrack('guide_view', { slug });
          } else if (path === '/sinistro-respinto') {
            window.sherlockTrack('landing_view', { landing: 'sinistro-respinto' });
          } else if (path === '/reclamo-ivass') {
            window.sherlockTrack('landing_view', { landing: 'reclamo-ivass' });
          } else if (path === '/arbitro-assicurativo') {
            window.sherlockTrack('landing_view', { landing: 'arbitro-assicurativo' });
          } else if (path === '/esempio-report') {
            window.sherlockTrack('example_report_view', {});
          } else if (path === '/esempio-lettera') {
            window.sherlockTrack('example_letter_view', {});
          } else if (path === '/trasparenza') {
            window.sherlockTrack('transparency_view', {});
          }

          // Delegated link click tracking. Categorizzo per destinazione.
          document.addEventListener('click', (e) => {
            const a = e.target.closest && e.target.closest('a[href]');
            if (!a) return;
            const href = a.getAttribute('href') || '';
            const label = (a.textContent || '').trim().slice(0, 60);
            const from = location.pathname;

            // Override esplicito via data-track="event_name" sull'<a>.
            const explicit = a.getAttribute('data-track');
            if (explicit) {
              window.sherlockTrack(explicit, { from_path: from, label });
              return;
            }

            if (href.includes('play.google.com/store/apps')) {
              window.sherlockTrack('play_store_click', { from_path: from, label });
            } else if (href === '/app/' || href === '/app' || href.startsWith('/app/') || href.startsWith('/app?')) {
              window.sherlockTrack('app_open_click', { from_path: from, label });
            } else if (href.startsWith('/abbonamento/')) {
              const piano = href.split('/abbonamento/')[1]?.split('?')[0]?.split('/')[0] || '';
              window.sherlockTrack('subscribe_plan_click', { piano, from_path: from });
            } else if (href === '/abbonati' || href.endsWith('/abbonati')) {
              window.sherlockTrack('paywall_view_intent', { from_path: from, label });
            } else if (href === '/esempio-report' || href.endsWith('/esempio-report')) {
              window.sherlockTrack('example_report_click', { from_path: from, label });
            } else if (href === '/esempio-lettera' || href.endsWith('/esempio-lettera')) {
              window.sherlockTrack('example_letter_click', { from_path: from, label });
            } else if (href === '/trasparenza' || href.endsWith('/trasparenza')) {
              window.sherlockTrack('transparency_click', { from_path: from, label });
            } else if (href === '/sinistro-respinto' || href.endsWith('/sinistro-respinto')) {
              window.sherlockTrack('landing_click', { landing: 'sinistro-respinto', from_path: from });
            } else if (href === '/reclamo-ivass' || href.endsWith('/reclamo-ivass')) {
              window.sherlockTrack('landing_click', { landing: 'reclamo-ivass', from_path: from });
            } else if (href === '/arbitro-assicurativo' || href.endsWith('/arbitro-assicurativo')) {
              window.sherlockTrack('landing_click', { landing: 'arbitro-assicurativo', from_path: from });
            } else if (href.startsWith('/guide/')) {
              const slug = href.replace('/guide/', '').replace(/\/$/, '').split('?')[0];
              window.sherlockTrack('guide_click', { slug, from_path: from });
            } else if (href === '/guide' || href.endsWith('/guide')) {
              window.sherlockTrack('guide_index_click', { from_path: from });
            }
          });

          // Track del PayPal click (il bottone PayPal è di solito un div
          // interattivo, non un <a>). Catturo qualsiasi click su elementi
          // con id/class che contenga 'paypal'.
          document.addEventListener('click', (e) => {
            const el = e.target.closest && e.target.closest('[id*="paypal" i], [class*="paypal" i], [data-payment="paypal"]');
            if (!el) return;
            window.sherlockTrack('paypal_click', { from_path: location.pathname });
          }, true);
        } catch (e) {
          // Silent: nessun blocco se Firebase non carica
        }
      })();
    </script>
  )}
</head>
<body class="bg-navy-950 text-navy-100 min-h-screen flex flex-col overflow-x-hidden">
  <div id="google_translate_element" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden" aria-hidden="true"></div>
  <slot name="header" />
  <main class="flex-1">
    <slot />
  </main>
  <slot name="footer" />
  <PwaUpdateToast />
  {enableGtag && <CookieBanner />}
  <script is:inline>
    // Su iOS l'app Android non è installabile: riscrivo i link Play Store
    // per puntare a /app/ (la stessa app WebView servita come PWA).
    (function () {
      var ua = navigator.userAgent || '';
      var isIos = /iPad|iPhone|iPod/.test(ua) || (/Macintosh/.test(ua) && 'ontouchend' in document);
      if (!isIos) return;
      var links = document.querySelectorAll('a[href*="play.google.com"]');
      for (var i = 0; i < links.length; i++) {
        var a = links[i];
        a.href = '/app/';
        a.removeAttribute('target');
        a.removeAttribute('rel');
        var txt = (a.textContent || '').toLowerCase();
        if (txt.indexOf('scarica') !== -1 || txt.indexOf('prova') !== -1 || txt.indexOf('app') !== -1) {
          a.textContent = 'Apri Sherlock';
        }
      }
    })();
  </script>
</body>
</html>
