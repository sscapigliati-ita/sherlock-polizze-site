---
// Pulsanti di condivisione virale: WhatsApp, Telegram, Copia link.
// Pensati per il "passaparola condominio/amici": testo precompilato suggerisce
// l'uso pratico ("guarda se ti torna utile") senza suonare promozionale.
interface Props {
  /** Titolo della pagina da condividere — incluso nel messaggio precompilato */
  title: string;
  /** Path della pagina (es. /guide/foo). Convertito in URL assoluto a runtime */
  path?: string;
  /** Variante intro: 'guide' (default) o 'storia' o 'app' */
  variant?: 'guide' | 'storia' | 'app';
}

const { title, path = '', variant = 'guide' } = Astro.props;

const intros = {
  guide: 'Ti potrebbe servire (o servire a qualcuno che conosci):',
  storia: 'Storia vera. Vale la lettura:',
  app: 'Guarda questa app, gratis, per leggere le polizze:',
};
const intro = intros[variant];
---
<div class="my-8 rounded-xl border border-navy-700 bg-navy-900/50 p-5">
  <div class="text-xs uppercase tracking-widest text-gold-400 font-bold mb-2">Conoscere qualcuno a cui può servire?</div>
  <p class="text-sm text-navy-300 mb-4 leading-relaxed">
    Mandagli il link in un secondo. Polizze e sinistri sono cose che capitano a tutti — e di solito
    nel momento peggiore.
  </p>
  <div class="flex flex-wrap gap-2" data-share-buttons data-title={title} data-path={path} data-intro={intro}>
    <button type="button" data-share="whatsapp" class="flex items-center gap-2 bg-[#25d366] hover:bg-[#1ebe5d] text-white font-semibold px-4 py-2.5 rounded-lg transition text-sm">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/></svg>
      WhatsApp
    </button>
    <button type="button" data-share="telegram" class="flex items-center gap-2 bg-[#229ed9] hover:bg-[#1c8bc1] text-white font-semibold px-4 py-2.5 rounded-lg transition text-sm">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.473-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      Telegram
    </button>
    <button type="button" data-share="copy" class="flex items-center gap-2 bg-navy-800 hover:bg-navy-700 border border-navy-600 text-navy-100 font-semibold px-4 py-2.5 rounded-lg transition text-sm">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span data-copy-label>Copia link</span>
    </button>
  </div>
</div>

<script is:inline>
(function(){
  if (window.__sherlockShareInit) return;
  window.__sherlockShareInit = true;
  document.addEventListener('click', function(e){
    var btn = e.target.closest && e.target.closest('[data-share]');
    if (!btn) return;
    var wrap = btn.closest('[data-share-buttons]');
    if (!wrap) return;
    var path = wrap.getAttribute('data-path') || location.pathname;
    var title = wrap.getAttribute('data-title') || document.title || 'Sherlock — Detective Polizze';
    var intro = wrap.getAttribute('data-intro') || 'Ti potrebbe servire:';
    var url = location.origin + path;
    var msg = intro + '\n\n' + title + '\n' + url;
    var kind = btn.getAttribute('data-share');
    try {
      if (typeof gtag === 'function') gtag('event', 'share_click', { kind: kind, page: path });
      if (window.sherlockTrack) window.sherlockTrack('share_click', { kind: kind, page: path });
    } catch(e){}
    if (kind === 'whatsapp') {
      window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank', 'noopener');
    } else if (kind === 'telegram') {
      window.open('https://t.me/share/url?url=' + encodeURIComponent(url) + '&text=' + encodeURIComponent(intro + ' ' + title), '_blank', 'noopener');
    } else if (kind === 'copy') {
      var lbl = btn.querySelector('[data-copy-label]');
      var prev = lbl ? lbl.textContent : '';
      var doneOk = function(){ if (lbl) { lbl.textContent = 'Copiato!'; setTimeout(function(){ lbl.textContent = prev; }, 1800); } };
      var doneErr = function(){ if (lbl) { lbl.textContent = 'Errore copia'; setTimeout(function(){ lbl.textContent = prev; }, 1800); } };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(doneOk).catch(doneErr);
      } else {
        // fallback iOS Safari vecchi
        var ta = document.createElement('textarea');
        ta.value = url; ta.style.position = 'fixed'; ta.style.top = 0; ta.style.left = 0;
        document.body.appendChild(ta); ta.focus(); ta.select();
        try { document.execCommand('copy'); doneOk(); } catch(e){ doneErr(); }
        document.body.removeChild(ta);
      }
    }
  });
})();
</script>
