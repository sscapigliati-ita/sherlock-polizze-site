---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { contaFounderVenduti } from '../lib/storage';
import { FOUNDER_MAX } from '../lib/paypal';

const playStoreUrl = 'https://play.google.com/store/apps/details?id=it.sherlock.polizze';

// Recupera il counter Founder live (KV). Se KV non risponde, fallback a 0
// (offerta visibile). Non bloccare mai il rendering della pagina per questo.
let founderVenduti = 0;
try {
  founderVenduti = await contaFounderVenduti();
} catch {}
const founderRimanenti = Math.max(0, FOUNDER_MAX - founderVenduti);
const founderAttivo = founderRimanenti > 0;

// Costruisco la lista piani dinamicamente. Founder appare SOLO se ci sono posti.
const piani = [
  ...(founderAttivo
    ? [{
        id: 'founder',
        nome: 'Founder (lifetime)',
        prezzo: '19,90 €',
        alMese: 'una tantum, accesso per sempre',
        badge: `Solo ${founderRimanenti}/${FOUNDER_MAX}`,
        recommended: true,
      }]
    : []),
  { id: 'mensile', nome: 'Mensile', prezzo: '2,99 €', alMese: '2,99 €/mese', badge: null, recommended: !founderAttivo && false },
  { id: 'semestrale', nome: 'Semestrale', prezzo: '7,99 €', alMese: '1,33 €/mese', badge: 'Risparmi 55%', recommended: false },
  { id: 'annuale', nome: 'Annuale', prezzo: '14,99 €', alMese: '1,25 €/mese', badge: founderAttivo ? 'Più conveniente (no Founder)' : 'Più conveniente', recommended: !founderAttivo },
];

const faqItems = [
  {
    q: 'Sherlock sostituisce un avvocato o un consulente assicurativo?',
    a: "No. Sherlock è uno strumento di analisi AI che fornisce informazioni a scopo orientativo. Per consulenza legale o assicurativa professionale è necessario rivolgersi a un avvocato o un consulente iscritto all'albo.",
  },
  {
    q: 'Che tipo di polizze posso analizzare?',
    a: 'Polizze auto, casa, vita, salute, infortuni, RC professionale, viaggio e ramo danni in generale.',
  },
  {
    q: 'Le lettere generate hanno valore legale?',
    a: "Sherlock genera documenti strutturati con i riferimenti normativi corretti, pronti da firmare e inviare via PEC. La validità legale dipende dalla situazione specifica.",
  },
  {
    q: "Come funziona il pagamento?",
    a: "Pagamento sicuro via PayPal sul sito web di Sherlock (non all'interno dell'app), in conformità con il Digital Markets Act (Regolamento UE 2022/1925), che permette agli sviluppatori di offrire metodi di pagamento alternativi ai sistemi di billing degli store. Nessun rinnovo automatico: alla scadenza puoi decidere se rinnovare. Disdici quando vuoi.",
  },
  {
    q: 'Posso usarlo su più dispositivi?',
    a: "Sì. L'abbonamento è legato alla tua email: lo attivi inserendo lo stesso codice su qualsiasi telefono Android.",
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Sherlock — Detective Polizze',
    description: 'Analisi AI delle polizze assicurative italiane',
    image: 'https://i.ibb.co/Y4MpcWtN/og-cover.png',
    brand: { '@type': 'Brand', name: 'Sherlock' },
    offers: piani.map((p) => ({
      '@type': 'Offer',
      name: `Piano ${p.nome}`,
      price: p.prezzo.replace('€', '').replace(',', '.').trim(),
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
      url: 'https://sherlock-polizze-site-five.vercel.app/abbonati',
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<BaseLayout
  title="Sherlock — Abbonati da 2,99€ | Analisi AI illimitate delle polizze"
  description="Sottoscrivi Sherlock Pro: analisi illimitate, lettere di reclamo, ricorsi IVASS e diffide pronte all'uso. Pagamento sicuro PayPal. Da 1,25€/mese con il piano annuale."
  jsonLd={jsonLd}
>
  <Header slot="header" />

  <section class="px-5 pt-12 pb-6 max-w-5xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-gold-400/10 border border-gold-400/30 px-3 py-1 rounded-full text-xs text-gold-400 font-semibold mb-5">
      Analisi illimitate · Lettere Pro · Nessun rinnovo automatico
    </div>
    <h1 class="text-4xl lg:text-5xl font-extrabold text-white tracking-tight mb-4">
      Scegli il tuo <span class="text-gold-400">piano</span>
    </h1>
    <p class="text-lg text-navy-300 max-w-2xl mx-auto">
      Sherlock Pro trasforma le criticità trovate nella polizza in
      reclami, diffide e segnalazioni IVASS strutturate.
    </p>

    {founderAttivo && (
      <div class="mt-7 inline-flex flex-col sm:flex-row items-center gap-3 px-5 py-3 rounded-xl border border-gold-400/40 bg-gradient-to-br from-amber-500/10 to-gold-400/10">
        <div class="text-xs uppercase tracking-widest text-gold-400 font-extrabold">🏆 Founder lifetime</div>
        <div class="text-sm text-white">
          <strong>19,90€ una sola volta — accesso Pro per sempre.</strong>
          Solo per i primi {FOUNDER_MAX} utenti (<span class="text-gold-400 font-bold">{founderRimanenti} ancora disponibili</span>).
        </div>
      </div>
    )}
  </section>

  <section class="px-5 pb-16 max-w-5xl mx-auto" id="checkout">
    <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-6">

      <!-- COLONNA SINISTRA: selezione piano -->
      <div>
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Seleziona il piano</div>
        <div class="space-y-3" id="piani-list">
          {piani.map((p, i) => (
            <label
              for={`p-${p.id}`}
              data-piano={p.id}
              data-prezzo={p.prezzo}
              class={`piano-radio block rounded-xl border p-5 cursor-pointer transition ${p.recommended ? 'border-gold-400 bg-gradient-to-br from-navy-800 to-navy-900' : 'border-navy-700 bg-navy-900 hover:border-navy-600'}`}
            >
              <input
                type="radio"
                name="piano"
                id={`p-${p.id}`}
                value={p.id}
                checked={p.recommended}
                class="hidden peer"
              />
              <div class="flex items-center gap-4">
                <div class="w-5 h-5 rounded-full border-2 border-navy-500 flex items-center justify-center flex-shrink-0 piano-dot">
                  <div class="w-2.5 h-2.5 rounded-full bg-gold-400 hidden piano-dot-inner"></div>
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-bold text-white text-lg">{p.nome}</span>
                    {p.badge && (
                      <span class={`text-[10px] uppercase tracking-widest font-bold px-2 py-0.5 rounded ${p.recommended ? 'bg-gold-400 text-navy-900' : 'bg-emerald-500/15 text-emerald-300 border border-emerald-500/30'}`}>
                        {p.badge}
                      </span>
                    )}
                  </div>
                  <div class="text-sm text-navy-300">{p.alMese}</div>
                </div>
                <div class="text-right">
                  <div class="text-2xl font-extrabold text-white">{p.prezzo}</div>
                  <div class="text-xs text-navy-400">una tantum</div>
                </div>
              </div>
            </label>
          ))}
        </div>

        <!-- Tabella comparativa -->
        <div class="mt-6 rounded-xl border border-navy-700 bg-navy-900 overflow-hidden">
          <div class="grid grid-cols-3 text-[11px] uppercase tracking-widest text-navy-400 font-bold p-3 border-b border-navy-800">
            <div>Piano</div><div class="text-right">Prezzo</div><div class="text-right">Al mese</div>
          </div>
          {piani.map((p) => (
            <div class="grid grid-cols-3 p-3 border-b border-navy-800 last:border-0 text-sm">
              <div class="text-navy-200 capitalize">{p.nome}</div>
              <div class="text-right text-white font-bold">{p.prezzo}</div>
              <div class="text-right text-gold-300">{p.alMese.replace('/mese', '')}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- COLONNA DESTRA: riassunto + email + PayPal -->
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <div class="rounded-xl border border-gold-400/30 bg-gradient-to-br from-navy-900 to-navy-800 p-6 shadow-xl shadow-gold-400/10">
          <div class="text-xs uppercase tracking-widest text-gold-400 font-bold mb-2">Riepilogo</div>
          <div class="text-2xl font-extrabold text-white mb-1" id="summary-titolo">Piano Annuale — 14,99 €</div>
          <div class="text-sm text-navy-300 mb-5" id="summary-sub">Equivalente a 1,25 €/mese</div>

          <form id="form-pay" class="space-y-4">
            <input type="hidden" name="piano" id="piano-hidden" value="annuale" />
            <div>
              <label for="email" class="block text-sm text-gray-300 mb-2">La tua email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="nome@esempio.it"
                class="w-full bg-navy-950 border border-navy-700 text-white rounded-lg px-4 py-3 focus:border-gold-400 focus:outline-none focus:ring-2 focus:ring-gold-400/20"
              />
              <p class="text-xs text-navy-500 mt-2">Riceverai il codice di attivazione qui. Usa la stessa email nell'app.</p>
            </div>

            <button
              type="submit"
              id="btn-pay"
              class="w-full bg-[#ffc439] hover:bg-[#f5b800] text-slate-900 font-bold py-3.5 rounded-lg transition flex items-center justify-center gap-2"
            >
              <span id="btn-pay-text">Continua con PayPal</span>
            </button>

            <div id="err-pay" class="hidden bg-red-500/10 border border-red-500/30 text-red-300 rounded-lg px-4 py-3 text-sm"></div>

            <ul class="space-y-2 text-xs text-navy-300 pt-3 border-t border-navy-700">
              <li class="flex items-start gap-2">
                <span class="text-emerald-400 mt-0.5">✓</span>
                <span>Analisi illimitate attivate subito</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-400 mt-0.5">✓</span>
                <span>Riceverai il codice di attivazione via email</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-400 mt-0.5">✓</span>
                <span>Pagamento sicuro PayPal · nessun rinnovo automatico</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-400 mt-0.5">✓</span>
                <span>Soddisfatti o rimborsati entro 7 giorni</span>
              </li>
            </ul>
          </form>
        </div>
      </aside>
    </div>
  </section>

  <section class="bg-navy-900 border-y border-navy-800 px-5 py-14">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-extrabold text-white text-center mb-10">Cosa include l'abbonamento</h2>
      <div class="grid md:grid-cols-2 gap-4 text-navy-200">
        {[
          'Analisi illimitate di polizze auto, casa, vita, salute, infortuni, RC professionale',
          'Lettera di reclamo formale pronta per PEC',
          'Esposto/ricorso IVASS pre-compilato',
          'Diffida stragiudiziale con riferimenti normativi corretti',
          'Sintesi operativa: cosa fare e cosa chiedere alla compagnia',
          'Raccomandazioni personalizzate sul tuo caso specifico',
          'Aggiornamenti continui delle clausole problematiche tracciate',
          'Privacy trasparente: documenti non conservati (dettagli sulla pagina Trasparenza)',
        ].map(item => (
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-gold-400/15 text-gold-400 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                <path fill-rule="evenodd" d="M16.704 5.295a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.295-7.29a1 1 0 011.41-.001z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="text-sm leading-relaxed">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-5 pb-8 max-w-3xl mx-auto">
    <div class="rounded-xl border border-navy-700 bg-navy-900 p-6 text-center">
      <div class="text-sm text-navy-300 mb-2">Ti serve solo <strong class="text-white">una lettera per una pratica singola</strong>?</div>
      <a href="/reclamo-singolo" class="inline-block text-gold-400 hover:text-gold-300 font-bold">
        Acquisto singolo a 3,99€ →
      </a>
      <div class="text-xs text-navy-500 mt-2">
        Codice usa-e-getta per generare 1 reclamo/IVASS/diffida. Nessun abbonamento.
      </div>
    </div>
  </section>

  <section class="px-5 py-16 max-w-3xl mx-auto">
    <h2 class="text-3xl font-extrabold text-white text-center mb-10">Domande frequenti</h2>
    <div class="space-y-3">
      {faqItems.map((f) => (
        <details class="bg-navy-900 border border-navy-800 rounded-xl group">
          <summary class="cursor-pointer p-5 font-semibold text-white flex justify-between items-center list-none">
            <span>{f.q}</span>
            <span class="text-gold-400 text-2xl leading-none group-open:rotate-45 transition">+</span>
          </summary>
          <div class="px-5 pb-5 text-navy-300 leading-relaxed">{f.a}</div>
        </details>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const DETT = {
    mensile: { titolo: 'Piano Mensile — 2,99 €', sub: 'Equivalente a 2,99 €/mese' },
    semestrale: { titolo: 'Piano Semestrale — 7,99 €', sub: 'Equivalente a 1,33 €/mese · Risparmi 55%' },
    annuale: { titolo: 'Piano Annuale — 14,99 €', sub: 'Equivalente a 1,25 €/mese · Risparmi 58%' },
  } as const;
  type Piano = keyof typeof DETT;

  function aggiornaUI(p: Piano) {
    const titolo = document.getElementById('summary-titolo');
    const sub = document.getElementById('summary-sub');
    const hid = document.getElementById('piano-hidden') as HTMLInputElement | null;
    const btnText = document.getElementById('btn-pay-text');
    if (titolo) titolo.textContent = DETT[p].titolo;
    if (sub) sub.textContent = DETT[p].sub;
    if (hid) hid.value = p;
    if (btnText) btnText.textContent = `Continua con PayPal · ${DETT[p].titolo.split('—')[1]?.trim() ?? ''}`;
    document.querySelectorAll('.piano-radio').forEach((el) => {
      const labelEl = el as HTMLElement;
      const attivo = labelEl.dataset.piano === p;
      labelEl.classList.toggle('!border-gold-400', attivo);
      const dot = labelEl.querySelector('.piano-dot') as HTMLElement | null;
      const dotInner = labelEl.querySelector('.piano-dot-inner') as HTMLElement | null;
      if (dot) dot.classList.toggle('!border-gold-400', attivo);
      if (dotInner) dotInner.classList.toggle('hidden', !attivo);
    });
  }

  document.querySelectorAll('input[name="piano"]').forEach((r) => {
    r.addEventListener('change', (e) => {
      const v = (e.target as HTMLInputElement).value as Piano;
      aggiornaUI(v);
    });
  });
  // Inizializza UI con il piano selezionato di default (annuale)
  const checked = document.querySelector<HTMLInputElement>('input[name="piano"]:checked');
  if (checked) aggiornaUI(checked.value as Piano);

  const form = document.getElementById('form-pay') as HTMLFormElement | null;
  const btn = document.getElementById('btn-pay') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-pay-text');
  const err = document.getElementById('err-pay') as HTMLDivElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !err) return;
    const fd = new FormData(form);
    const piano = String(fd.get('piano') ?? 'annuale');
    const email = String(fd.get('email') ?? '').trim();
    btn.disabled = true;
    if (btnText) btnText.textContent = 'Reindirizzamento a PayPal…';
    err.classList.add('hidden');
    try {
      const r = await fetch('/api/paypal/create-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ piano, email }),
      });
      const data = await r.json();
      if (!r.ok || !data.approveUrl) throw new Error(data.error ?? 'Errore inatteso');
      sessionStorage.setItem('sherlock_pending', JSON.stringify({ piano, email, orderId: data.orderId }));
      window.location.href = data.approveUrl;
    } catch (e: any) {
      err.textContent = e?.message ?? 'Errore';
      err.classList.remove('hidden');
      btn.disabled = false;
      if (btnText) btnText.textContent = 'Riprova';
    }
  });
</script>
