---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guide')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout
  title="Guide alle assicurazioni — Sherlock"
  description="Guide pratiche su reclami, esposti IVASS, diffide e clausole abusive nelle polizze assicurative italiane. Aggiornate al 2026."
>
  <Header slot="header" />

  <section class="px-5 pt-14 pb-10 max-w-4xl mx-auto text-center">
    <h1 class="text-4xl lg:text-5xl font-extrabold text-white tracking-tight mb-4">
      Guide alle <span class="text-gold-400">assicurazioni</span>
    </h1>
    <p class="text-navy-300 text-lg">
      Reclami, esposti IVASS, diffide e clausole abusive. Tutto quello che ti serve
      per far valere i tuoi diritti.
    </p>
  </section>

  <section class="px-5 pb-6 max-w-4xl mx-auto">
    <a
      href="/arbitro-assicurativo"
      class="block bg-gradient-to-br from-navy-800 to-navy-900 border border-gold-400/40 rounded-xl p-6 hover:border-gold-400 transition group"
    >
      <div class="text-xs uppercase tracking-widest text-gold-400 mb-2 font-bold">
        Guida pilastro · caso studio documentato
      </div>
      <h2 class="text-2xl font-extrabold text-white group-hover:text-gold-300 transition mb-2">
        Ricorso all'Arbitro Assicurativo: la guida di chi l'ha fatto
      </h2>
      <p class="text-navy-200 text-sm leading-relaxed mb-3">
        Prerequisiti del ricorso, requisiti formali, errori tipici che
        possono costare il ricorso, checklist pre-invio. Scritta partendo
        da un ricorso presentato in prima persona.
      </p>
      <div class="text-sm text-gold-400 font-semibold">Leggi la guida completa →</div>
    </a>
  </section>

  <section class="px-5 pb-20 max-w-4xl mx-auto">
    <div class="grid gap-5">
      {guides.map((g) => (
        <a
          href={`/guide/${g.id.replace(/\.mdx?$/, '')}`}
          class="block bg-navy-900 border border-navy-800 hover:border-gold-400/40 rounded-xl p-6 transition group"
        >
          <div class="text-xs uppercase tracking-widest text-gold-400 mb-2">
            {new Date(g.data.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-gold-300 transition mb-2">
            {g.data.title}
          </h2>
          <p class="text-navy-300 text-sm leading-relaxed">{g.data.description}</p>
          <div class="mt-3 text-sm text-gold-400 font-semibold">Leggi la guida →</div>
        </a>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
