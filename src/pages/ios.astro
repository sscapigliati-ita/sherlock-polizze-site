---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'Installare Sherlock su iPhone',
    description: 'Guida rapida per installare Sherlock come app sul tuo iPhone tramite Safari (Aggiungi a Home).',
    inLanguage: 'it-IT',
    step: [
      { '@type': 'HowToStep', position: 1, name: 'Apri Safari', text: 'Su iPhone apri Safari (non Chrome). L\'installazione PWA funziona solo dal browser di sistema.' },
      { '@type': 'HowToStep', position: 2, name: 'Vai su sherlockpolizze.it/app', text: 'Digita l\'indirizzo www.sherlockpolizze.it/app oppure tocca il pulsante qui sotto.' },
      { '@type': 'HowToStep', position: 3, name: 'Tocca il pulsante Condividi', text: 'Tocca il pulsante Condividi in fondo alla schermata Safari (quadrato con freccia verso l\'alto).' },
      { '@type': 'HowToStep', position: 4, name: 'Aggiungi alla schermata Home', text: 'Scorri le opzioni e tocca "Aggiungi a Home". Poi conferma con "Aggiungi".' },
      { '@type': 'HowToStep', position: 5, name: 'Apri Sherlock dalla Home', text: 'L\'icona di Sherlock appare come una vera app: aprila e inizia l\'analisi.' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.sherlockpolizze.it/' },
      { '@type': 'ListItem', position: 2, name: 'Sherlock su iPhone', item: 'https://www.sherlockpolizze.it/ios' },
    ],
  },
];
---
<BaseLayout
  title="Sherlock su iPhone: installa la web app in 4 tap"
  description="Sherlock non è (ancora) sull'App Store. Su iPhone si installa come app dal browser Safari: bastano 4 tap. Guida passo passo con screenshot."
  jsonLd={jsonLd}
>
  <Header slot="header" />

  <article class="px-5 py-12 max-w-4xl mx-auto">
    <nav class="text-xs text-navy-500 mb-6">
      <a href="/" class="hover:text-gold-300">Home</a> · Sherlock su iPhone
    </nav>

    <div class="inline-flex items-center gap-2 bg-navy-800/60 border border-navy-700 px-3 py-1 rounded-full text-xs text-navy-300 font-semibold mb-5">
      <svg viewBox="0 0 384 512" class="w-3.5 h-3.5" aria-hidden="true">
        <path fill="currentColor" d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
      </svg>
      Guida iOS · iPhone e iPad
    </div>

    <h1 class="text-4xl lg:text-5xl font-extrabold text-white tracking-tight leading-tight mb-5">
      Sherlock su iPhone:<br />
      <span class="text-gold-400">installa la web app in 4 tap.</span>
    </h1>
    <p class="text-lg text-navy-300 leading-relaxed mb-8">
      Sherlock non è (ancora) sull'App Store, ma funziona già come vera app su iPhone e iPad.
      È una <strong class="text-white">Progressive Web App</strong>: si installa dal browser
      Safari e si apre a schermo intero come un'app normale, con icona sulla Home.
      Stesso backend, stesse funzioni della versione Android.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 mb-12">
      <a href="/app/" class="bg-gold-400 text-navy-900 font-bold px-6 py-3.5 rounded-lg hover:bg-gold-300 transition shadow-xl shadow-gold-400/20 text-center">
        Apri Sherlock ora (Safari)
      </a>
      <a href="/abbonati" class="border border-navy-600 text-navy-100 font-semibold px-6 py-3.5 rounded-lg hover:bg-navy-800 transition text-center">
        Vedi i piani
      </a>
    </div>

    <div class="bg-gold-400/5 border border-gold-400/30 rounded-xl p-5 mb-12">
      <div class="text-sm text-navy-100 leading-relaxed">
        <strong class="text-gold-300">Importante:</strong> l'installazione via "Aggiungi a Home"
        funziona solo da <strong class="text-white">Safari</strong>. Se stai leggendo questa
        pagina da Chrome/Firefox su iPhone, copia il link e aprilo in Safari.
      </div>
    </div>

    <h2 class="text-2xl font-bold text-white mb-6">Come installare Sherlock su iPhone</h2>

    <ol class="space-y-6 mb-12">
      <li class="flex gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold-400 text-navy-900 font-extrabold flex items-center justify-center text-lg">1</div>
        <div>
          <h3 class="text-lg font-bold text-white mb-1">Apri Safari</h3>
          <p class="text-navy-300 text-sm leading-relaxed">
            Sul tuo iPhone o iPad apri l'app <strong class="text-white">Safari</strong>.
            L'installazione come app funziona solo dal browser di sistema Apple.
          </p>
        </div>
      </li>

      <li class="flex gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold-400 text-navy-900 font-extrabold flex items-center justify-center text-lg">2</div>
        <div>
          <h3 class="text-lg font-bold text-white mb-1">Vai su sherlockpolizze.it/app</h3>
          <p class="text-navy-300 text-sm leading-relaxed">
            Digita nella barra Safari <code class="bg-navy-800 text-gold-300 px-1.5 py-0.5 rounded text-xs">www.sherlockpolizze.it/app</code>
            e aspetta che la pagina si carichi completamente.
          </p>
        </div>
      </li>

      <li class="flex gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold-400 text-navy-900 font-extrabold flex items-center justify-center text-lg">3</div>
        <div>
          <h3 class="text-lg font-bold text-white mb-1">Tocca il pulsante Condividi</h3>
          <p class="text-navy-300 text-sm leading-relaxed mb-2">
            In fondo alla schermata Safari tocca l'icona <strong class="text-white">Condividi</strong>
            (quadrato con freccia verso l'alto). Su iPad la trovi in alto a destra.
          </p>
          <div class="inline-flex items-center gap-2 bg-navy-800 border border-navy-700 rounded-lg px-3 py-2 text-xs text-navy-300">
            <svg viewBox="0 0 24 24" class="w-4 h-4 text-gold-400" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 16V4M12 4l-4 4M12 4l4 4"/>
              <rect x="4" y="12" width="16" height="8" rx="2"/>
            </svg>
            l'icona con la freccia verso l'alto
          </div>
        </div>
      </li>

      <li class="flex gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold-400 text-navy-900 font-extrabold flex items-center justify-center text-lg">4</div>
        <div>
          <h3 class="text-lg font-bold text-white mb-1">Aggiungi alla schermata Home</h3>
          <p class="text-navy-300 text-sm leading-relaxed">
            Scorri le opzioni del pannello di condivisione fino a trovare
            <strong class="text-white">"Aggiungi a Home"</strong>. Toccala, poi conferma con
            <strong class="text-white">"Aggiungi"</strong> in alto a destra. L'icona di Sherlock
            appare sulla tua Home come una vera app: aprila e sei pronto ad analizzare la prima polizza.
          </p>
        </div>
      </li>
    </ol>

    <h2 class="text-2xl font-bold text-white mb-4">Cosa funziona su iPhone</h2>
    <div class="grid sm:grid-cols-2 gap-4 mb-12">
      <div class="bg-navy-900 border border-navy-700 rounded-xl p-5">
        <div class="text-sm font-semibold text-gold-300 mb-2">✓ Analisi polizza completa</div>
        <p class="text-navy-300 text-sm leading-relaxed">
          Carichi il PDF dal Files iOS o dagli allegati mail. L'AI legge, identifica
          esclusioni, clausole vessatorie e livello di rischio.
        </p>
      </div>
      <div class="bg-navy-900 border border-navy-700 rounded-xl p-5">
        <div class="text-sm font-semibold text-gold-300 mb-2">✓ Scatta foto della polizza</div>
        <p class="text-navy-300 text-sm leading-relaxed">
          Il pulsante "Scatta foto" apre la fotocamera iPhone: fotografi la polizza cartacea
          e Sherlock la analizza direttamente.
        </p>
      </div>
      <div class="bg-navy-900 border border-navy-700 rounded-xl p-5">
        <div class="text-sm font-semibold text-gold-300 mb-2">✓ Lettere Pro pronte da inviare</div>
        <p class="text-navy-300 text-sm leading-relaxed">
          Con Sherlock Pro (o l'offerta Founder) generi reclamo, esposto IVASS e diffida
          in italiano formale, con riferimenti normativi.
        </p>
      </div>
      <div class="bg-navy-900 border border-navy-700 rounded-xl p-5">
        <div class="text-sm font-semibold text-gold-300 mb-2">✓ Pagamento PayPal fuori app</div>
        <p class="text-navy-300 text-sm leading-relaxed">
          Il paywall porta al sito, paghi con PayPal e ricevi il codice via email:
          lo inserisci nell'app e sblocchi Pro su iPhone e Android.
        </p>
      </div>
    </div>

    <h2 class="text-2xl font-bold text-white mb-4">Prova gratuita e piani</h2>
    <p class="text-navy-300 leading-relaxed mb-4">
      Su iPhone (come su web) hai <strong class="text-white">1 analisi gratuita completa</strong>
      per capire come funziona Sherlock. Per continuare hai tre opzioni chiare, senza rinnovo automatico:
    </p>
    <ul class="space-y-3 text-navy-200 mb-8">
      <li><strong class="text-gold-300">Lettera Singola — 3,99€</strong> · Codice usa-e-getta valido 30 giorni. Zero abbonamento.</li>
      <li><strong class="text-gold-300">Pass Pro Founder — 19,90€ una tantum</strong> · Accesso Pro a vita, solo per i primi 50 iscritti.</li>
      <li><strong class="text-gold-300">Pass Pro mensile / semestrale / annuale</strong> · Da 2,99€, senza rinnovo automatico.</li>
    </ul>

    <div class="flex flex-col sm:flex-row gap-3 mb-16">
      <a href="/app/" class="bg-gold-400 text-navy-900 font-bold px-6 py-3.5 rounded-lg hover:bg-gold-300 transition shadow-xl shadow-gold-400/20 text-center">
        Prova ora (1 analisi gratis)
      </a>
      <a href="/abbonati" class="border border-navy-600 text-navy-100 font-semibold px-6 py-3.5 rounded-lg hover:bg-navy-800 transition text-center">
        Vedi tutti i piani
      </a>
    </div>

    <h2 class="text-2xl font-bold text-white mb-4">Domande frequenti</h2>
    <div class="space-y-3 mb-16">
      <details class="bg-navy-900 border border-navy-700 rounded-xl p-5">
        <summary class="cursor-pointer text-white font-semibold">Perché Sherlock non è sull'App Store?</summary>
        <p class="text-navy-300 text-sm leading-relaxed mt-3">
          Al momento offriamo Sherlock come Progressive Web App per iPhone. Stiamo valutando la
          pubblicazione nativa sull'App Store, ma nel frattempo l'installazione via Safari dà la
          stessa esperienza: icona in Home, apertura a schermo intero, notifiche di aggiornamento.
        </p>
      </details>
      <details class="bg-navy-900 border border-navy-700 rounded-xl p-5">
        <summary class="cursor-pointer text-white font-semibold">Devo pagare qualcosa per installarla?</summary>
        <p class="text-navy-300 text-sm leading-relaxed mt-3">
          No. L'installazione da Safari e la prima analisi sono gratuite. Paghi solo quando decidi
          di sbloccare le lettere legali o analisi illimitate.
        </p>
      </details>
      <details class="bg-navy-900 border border-navy-700 rounded-xl p-5">
        <summary class="cursor-pointer text-white font-semibold">Posso usarla anche da Mac o iPad?</summary>
        <p class="text-navy-300 text-sm leading-relaxed mt-3">
          Sì. Su iPad il flusso è identico all'iPhone. Su Mac (Safari 17+) puoi usare
          <em>File → Aggiungi al Dock</em> e Sherlock diventa un'app desktop.
        </p>
      </details>
      <details class="bg-navy-900 border border-navy-700 rounded-xl p-5">
        <summary class="cursor-pointer text-white font-semibold">L'abbonamento vale anche sull'app Android?</summary>
        <p class="text-navy-300 text-sm leading-relaxed mt-3">
          Sì. Il codice attivazione ricevuto via email funziona su iPhone (PWA), Android e web.
          Puoi passare da un dispositivo all'altro senza pagare di nuovo.
        </p>
      </details>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
