---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Sherlock — Lettera singola',
    description: 'Codice usa-e-getta per generare una lettera di reclamo/IVASS/diffida. Nessun abbonamento.',
    brand: { '@type': 'Brand', name: 'Sherlock' },
    offers: {
      '@type': 'Offer',
      price: '3.99',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
      url: 'https://www.sherlockpolizze.it/reclamo-singolo',
    },
  },
];
---
<BaseLayout
  title="Reclamo singolo a 3,99€ — Sherlock"
  description="Acquisto una-tantum: paghi 3,99€ e generi UNA lettera di reclamo (PEC, esposto IVASS o diffida) sulla tua pratica. Nessun abbonamento."
  jsonLd={jsonLd}
>
  <Header slot="header" />

  <section class="px-5 pt-12 pb-6 max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-gold-400/10 border border-gold-400/30 px-3 py-1 rounded-full text-xs text-gold-400 font-semibold mb-5">
      Una sola pratica · Nessun abbonamento · Pagamento sicuro PayPal
    </div>
    <h1 class="text-4xl lg:text-5xl font-extrabold text-white tracking-tight mb-4">
      <span class="text-gold-400">Una lettera</span>, una sola volta.
    </h1>
    <p class="text-lg text-navy-300 max-w-xl mx-auto">
      Hai una pratica singola da chiudere? Paghi <strong class="text-white">3,99€ una volta</strong>
      e ricevi un codice per generare <strong class="text-white">1 lettera</strong>
      (PEC, esposto IVASS o diffida — scegli tu dall'app). Nessun abbonamento.
    </p>
  </section>

  <section class="px-5 pb-16 max-w-3xl mx-auto">
    <div class="rounded-xl border border-gold-400/40 bg-gradient-to-br from-navy-900 to-navy-800 p-6 shadow-xl shadow-gold-400/10">
      <div class="grid sm:grid-cols-[1fr_auto] gap-4 items-center mb-6">
        <div>
          <div class="text-xs uppercase tracking-widest text-gold-400 font-bold mb-1">Acquisto singolo</div>
          <div class="text-2xl font-extrabold text-white">1 lettera Sherlock</div>
          <div class="text-sm text-navy-400">Codice usa-e-getta · valido 30 giorni</div>
        </div>
        <div class="text-right">
          <div class="text-4xl font-extrabold text-gold-400">3,99 €</div>
          <div class="text-xs text-navy-400">una tantum</div>
        </div>
      </div>

      <form id="form-singolo" class="space-y-3">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-navy-400 font-bold">Email di ricezione codice</span>
          <input
            type="email"
            name="email"
            required
            placeholder="tu@esempio.it"
            class="mt-1 w-full bg-navy-950 border border-navy-700 rounded-lg px-4 py-3 text-white placeholder-navy-500 focus:border-gold-400 focus:outline-none"
          />
        </label>
        <button
          type="submit"
          id="btn-paypal"
          class="w-full bg-gold-400 text-navy-900 font-bold px-6 py-4 rounded-lg hover:bg-gold-300 transition shadow-xl shadow-gold-400/20 disabled:opacity-50"
        >
          Paga 3,99€ con PayPal
        </button>
        <div id="errore" class="hidden text-sm text-red-300 bg-red-500/10 border border-red-500/30 rounded-lg px-4 py-3"></div>
        <p class="text-xs text-navy-500 leading-relaxed">
          Pagamento PayPal. Il codice arriva via email subito dopo. Lo inserisci in
          Sherlock (Impostazioni → Inserisci codice) e generi la tua lettera.
          Il codice si esaurisce dopo la 1ª generazione.
        </p>
      </form>
    </div>

    <div class="mt-8 grid sm:grid-cols-2 gap-4 text-sm">
      <div class="rounded-xl border border-navy-700 bg-navy-900 p-5">
        <div class="font-bold text-white mb-2">Quando ha senso il singolo</div>
        <ul class="space-y-1.5 text-navy-300">
          <li class="flex gap-2"><span class="text-emerald-400">✓</span> Hai 1 sola pratica aperta</li>
          <li class="flex gap-2"><span class="text-emerald-400">✓</span> Non vuoi pensare ad abbonamenti</li>
          <li class="flex gap-2"><span class="text-emerald-400">✓</span> Sai già che tipo di lettera ti serve</li>
        </ul>
      </div>
      <div class="rounded-xl border border-navy-700 bg-navy-900 p-5">
        <div class="font-bold text-white mb-2">Conviene Pro se</div>
        <ul class="space-y-1.5 text-navy-300">
          <li class="flex gap-2"><span class="text-gold-400">→</span> Hai più polizze da controllare</li>
          <li class="flex gap-2"><span class="text-gold-400">→</span> Vuoi confrontare più tipi di lettera</li>
          <li class="flex gap-2"><span class="text-gold-400">→</span> Tieni un'attività di review continua</li>
        </ul>
        <a href="/abbonati" class="inline-block mt-3 text-xs text-gold-400 hover:text-gold-300 font-bold">
          Vai ai piani Pro (da 2,99€/mese) →
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const form = document.getElementById('form-singolo') as HTMLFormElement | null;
  const btn = document.getElementById('btn-paypal') as HTMLButtonElement | null;
  const err = document.getElementById('errore') as HTMLDivElement | null;

  form?.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!btn) return;
    const fd = new FormData(form);
    const email = String(fd.get('email') || '').trim().toLowerCase();
    if (!email) return;

    err?.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Sto creando l\'ordine PayPal...';

    try {
      const w: any = window;
      const ref = typeof w.sherlockRef === 'function' ? w.sherlockRef() : null;
      const r = await fetch('/api/paypal/create-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ piano: 'singolo', email, ...(ref ? { ref } : {}) }),
      });
      const data = await r.json();
      if (!r.ok || !data.approveUrl) {
        throw new Error(data.error || 'Errore creazione ordine');
      }
      // Track event prima del redirect
      if (typeof w.sherlockTrack === 'function') {
        w.sherlockTrack('paypal_redirect_singolo', { value: 3.99, currency: 'EUR' });
      }
      window.location.href = data.approveUrl;
    } catch (e: any) {
      btn.disabled = false;
      btn.textContent = 'Paga 3,99€ con PayPal';
      if (err) {
        err.textContent = e?.message || 'Errore sconosciuto';
        err.classList.remove('hidden');
      }
    }
  });
</script>
