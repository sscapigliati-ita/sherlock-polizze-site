---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { leggiStats } from '../../lib/log';
import { leggiAbbonati, contaFounderVenduti, contaPayPalProcessing } from '../../lib/storage';
import { leggiUltimiEventi } from '../../lib/log';
import { leggiStabilitaApp, invalidaCachePlay } from '../../lib/play';
import { leggiAnalyticsProperty, invalidaCacheGa4, type AnalyticsResult } from '../../lib/ga4-data';
import { FOUNDER_MAX } from '../../lib/paypal';
import { statoStreamGa4 } from '../../lib/ga4';

// /admin?refresh=play forza il refresh della cache Play (bypass 6h TTL).
if (Astro.url.searchParams.get('refresh') === 'play') {
  await invalidaCachePlay();
}
// /admin?refresh=ga4 forza il refresh delle metriche GA4.
if (Astro.url.searchParams.get('refresh') === 'ga4') {
  await invalidaCacheGa4();
}

// Le chiamate esterne possono fallire (SA non configurato, permessi mancanti,
// quote): allSettled/catch per non rompere la dashboard.
const [stats, abb, eventi, stabRes, ga4Ads, ga4Firebase, founderVenduti, ppProc] = await Promise.all([
  leggiStats(),
  leggiAbbonati(),
  leggiUltimiEventi(50),
  leggiStabilitaApp().catch((e: any) => ({ errore: String(e?.message ?? e) }) as any),
  leggiAnalyticsProperty('GA4_PROPERTY_ID_ADS'),
  leggiAnalyticsProperty('GA4_PROPERTY_ID_FIREBASE'),
  contaFounderVenduti().catch(() => 0),
  contaPayPalProcessing().catch(() => ({
    total: 0, processing: 0, completed: 0, failed: 0, withCaptureId: 0, stuckProcessing: 0,
  })),
]);
const streamsConfigurati = statoStreamGa4();
const founderRimanenti = Math.max(0, FOUNDER_MAX - founderVenduti);
const founderPctVenduto = (founderVenduti / FOUNDER_MAX) * 100;
const ppCaptureCoverage = ppProc.completed > 0
  ? (ppProc.withCaptureId / ppProc.completed) * 100
  : 0;
const stab = ('crashRate28gg' in stabRes ? stabRes : null) as Awaited<ReturnType<typeof leggiStabilitaApp>> | null;
const stabError = (stabRes as any).errore as string | undefined;
const fmtPct = (n: number | null) => n === null ? '—' : `${n.toFixed(2)} %`;
const fmtNum = (n: number) => new Intl.NumberFormat('it-IT').format(n);

// Helper per iterare le due property nella stessa struttura
const profili: Array<{ titolo: string; codice: string; res: AnalyticsResult }> = [
  { titolo: 'sherlock polizze web', codice: 'G-21MQHMK771', res: ga4Ads },
  { titolo: 'sherlock-6f88c (Firebase)', codice: 'G-VVW7CNHTYJ', res: ga4Firebase },
];

const adminEmail = Astro.locals.adminEmail ?? '';
const ricavoEuro = (abb.ricavoEuroCent / 100).toFixed(2).replace('.', ',');

// ==== HEALTH SCORECARD "a colpo d'occhio" ====
// 5 dimensioni con score 0-100 e trend arrow (↗/↔/↘) rispetto ai giorni precedenti.
// Score aggregato = media dei 5. Semaforo: >=70 verde, 40-69 ambra, <40 rosso.

type Trend = 'up' | 'flat' | 'down' | 'na';
type Health = { score: number; label: string; big: string; note: string; trend: Trend };

// Confronto ultima metà (giorni 4-7) vs prima metà (giorni 1-3) di una serie di 7 valori.
// Ritorna 'up' se ratio > 1.15, 'down' se < 0.85, altrimenti 'flat'.
function calcolaTrend(serie: number[]): Trend {
  if (!serie || serie.length < 4) return 'na';
  const meta = Math.ceil(serie.length / 2);
  const first = serie.slice(0, meta).reduce((s, v) => s + v, 0) / meta;
  const last = serie.slice(meta).reduce((s, v) => s + v, 0) / Math.max(1, serie.length - meta);
  if (first === 0 && last === 0) return 'flat';
  if (first === 0) return 'up';
  const ratio = last / first;
  if (ratio > 1.15) return 'up';
  if (ratio < 0.85) return 'down';
  return 'flat';
}

// Score continuo con clamp 0-100.
function scoreLineare(valore: number, min0: number, max100: number): number {
  if (max100 === min0) return valore >= max100 ? 100 : 0;
  return Math.max(0, Math.min(100, ((valore - min0) / (max100 - min0)) * 100));
}
// Score inverso (peggiora al crescere): 100 se v<=okSotto, 0 se v>=criticoOltre.
function scoreInverso(valore: number | null, okSotto: number, criticoOltre: number): number {
  if (valore === null) return 50;
  if (valore <= okSotto) return 100;
  if (valore >= criticoOltre) return 0;
  return Math.max(0, Math.min(100, 100 - ((valore - okSotto) / (criticoOltre - okSotto)) * 100));
}

// FRUIZIONE — utenti attivi property Web GA4 (proxy del traffico organico sito)
const utentiOggi = ('utentiOggi' in ga4Ads) ? ga4Ads.utentiOggi : 0;
const utenti7gg = ('utenti7gg' in ga4Ads) ? ga4Ads.utenti7gg : 0;
const serieUtentiGiorno = ('serieUtenti' in ga4Ads) ? ga4Ads.serieUtenti.map((g) => g.utenti) : [];
const fruizione: Health = {
  // 100 se utenti oggi >= media 7gg × 1.5, 0 se = 0. Scala lineare.
  score: scoreLineare(utentiOggi, 0, Math.max(1, (utenti7gg / 7) * 1.5)),
  label: 'Fruizione',
  big: fmtNum(utentiOggi),
  note: `${fmtNum(utenti7gg)} utenti 7gg`,
  trend: calcolaTrend(serieUtentiGiorno),
};

// INSTALLAZIONE — proxy inverso: crash rate 28gg. Meno crash = utenti che restano.
// Le installazioni CSV dal bucket Play sono ferme upstream (documentato) → uso
// stability come proxy: se crash è alto, gli utenti disinstallano di più.
const crashRate = stab?.crashRate28gg ?? null;
const anrRate = stab?.anrRate28gg ?? null;
const installazione: Health = {
  score: crashRate === null ? 50 : scoreInverso(crashRate, 0.5, 2.5),
  label: 'Installazione',
  big: crashRate === null ? '—' : `${crashRate.toFixed(1)}%`,
  note: crashRate === null ? 'Play API n/d' : 'crash rate 28gg',
  trend: crashRate === null || stab === null
    ? 'na'
    : stab.crashRateOggi === null
      ? 'flat'
      : stab.crashRateOggi > (crashRate ?? 0) * 1.2 ? 'down'
      : stab.crashRateOggi < (crashRate ?? 0) * 0.8 ? 'up'
      : 'flat',
};

// UTILIZZO — analisi tentate oggi (proxy uso concreto dell'app+web)
const serieAnalisi = stats.perGiorno.map((g) => g.analisi);
const analisi7gg = serieAnalisi.reduce((s, v) => s + v, 0);
const utilizzo: Health = {
  score: scoreLineare(stats.analisiOggi, 0, Math.max(1, (analisi7gg / 7) * 1.5)),
  label: 'Utilizzo',
  big: fmtNum(stats.analisiOggi),
  note: `${fmtNum(analisi7gg)} analisi 7gg`,
  trend: calcolaTrend(serieAnalisi),
};

// UTILITÀ — quanti utenti trovano abbastanza valore da abbonarsi.
// Score: emette 100 se abb.attivi >= 30 (tetto arbitrario configurabile).
const utilita: Health = {
  score: scoreLineare(abb.attivi, 0, 30),
  label: 'Utilità',
  big: fmtNum(abb.attivi),
  note: `${fmtNum(abb.totali)} totali · ${ricavoEuro} €`,
  trend: abb.totali > abb.attivi + 5 ? 'flat' : abb.attivi > 0 ? 'up' : 'na',
};

// GRADIMENTO — combinazione di ANR (utenti che si arrabbiano) e ratio abbonati/utenti
// (se convertono, hanno gradito). Media pesata: 70% ANR inverso + 30% conversion.
const anrScore = anrRate === null ? 50 : scoreInverso(anrRate, 0.2, 1.0);
const conversionRate = utenti7gg > 0 ? (abb.attivi / utenti7gg) * 100 : 0;
const conversionScore = scoreLineare(conversionRate, 0, 5); // 5% conv → 100
const gradimento: Health = {
  score: Math.round(anrScore * 0.7 + conversionScore * 0.3),
  label: 'Gradimento',
  big: anrRate === null ? '—' : `${anrRate.toFixed(2)}%`,
  note: anrRate === null ? 'ANR n/d' : `ANR 28gg · conv ${conversionRate.toFixed(1)}%`,
  trend: stab && stab.anrRateOggi !== null && anrRate !== null
    ? stab.anrRateOggi > anrRate * 1.2 ? 'down'
      : stab.anrRateOggi < anrRate * 0.8 ? 'up'
      : 'flat'
    : 'na',
};

const dimensioni: Health[] = [fruizione, installazione, utilizzo, utilita, gradimento];
const scoreAggregato = Math.round(
  dimensioni.reduce((s, d) => s + d.score, 0) / dimensioni.length,
);
const scoreLabel = scoreAggregato >= 70 ? 'ottimo' : scoreAggregato >= 40 ? 'da monitorare' : 'critico';
const scoreColor = scoreAggregato >= 70 ? 'text-emerald-400' : scoreAggregato >= 40 ? 'text-amber-300' : 'text-red-400';
const scoreRing = scoreAggregato >= 70 ? 'stroke-emerald-400' : scoreAggregato >= 40 ? 'stroke-amber-300' : 'stroke-red-400';
const tileColor = (s: number) => s >= 70
  ? { border: 'border-emerald-500/40', bg: 'from-emerald-500/10 to-navy-900', num: 'text-emerald-400', bar: 'bg-emerald-400' }
  : s >= 40
  ? { border: 'border-amber-500/40', bg: 'from-amber-500/10 to-navy-900', num: 'text-amber-300', bar: 'bg-amber-300' }
  : { border: 'border-red-500/40', bg: 'from-red-500/10 to-navy-900', num: 'text-red-400', bar: 'bg-red-400' };
const trendGlyph = (t: Trend) => t === 'up' ? '↗' : t === 'down' ? '↘' : t === 'flat' ? '↔' : '·';
const trendColor = (t: Trend) => t === 'up' ? 'text-emerald-400' : t === 'down' ? 'text-red-300' : t === 'flat' ? 'text-navy-300' : 'text-navy-500';
const dimensionIcon = (label: string) => ({
  'Fruizione': '🌐',
  'Installazione': '📱',
  'Utilizzo': '🔍',
  'Utilità': '✉️',
  'Gradimento': '⭐',
} as Record<string, string>)[label] ?? '•';
// Cerchio SVG: raggio 42, circonferenza 264. Dash calcolato da score/100.
const ringDash = (scoreAggregato / 100) * 264;
const dataHealthNow = new Date().toLocaleString('it-IT', {
  timeZone: 'Europe/Rome',
  day: '2-digit', month: '2-digit', year: 'numeric',
  hour: '2-digit', minute: '2-digit',
});

const maxAnalisi = Math.max(1, ...stats.perGiorno.map((g) => g.analisi));
const oggiBreve = (g: string) => {
  const d = new Date(g);
  return d.toLocaleDateString('it-IT', { day: '2-digit', month: 'short' });
};

// Errori/bloccati per tipo: i counter sono stati introdotti dopo il go-live.
// Il "residuo" è la quota di errori storici aggregati prima dello split, che
// non possiamo riassegnare a un tipo specifico — la mostriamo come "pre-split"
// invece di gonfiare arbitrariamente una delle due colonne.
const erroriPreSplit = Math.max(
  0,
  stats.erroriTotali - stats.erroriAnalizzaTotali - stats.erroriLetteraTotali - stats.erroriComparaTotali,
);
const bloccatiPreSplit = Math.max(
  0,
  stats.bloccatiTotali - stats.bloccatiAnalizzaTotali - stats.bloccatiLetteraTotali - stats.bloccatiComparaTotali,
);

// Vercel functions girano in UTC; forzo Europe/Rome così la dashboard mostra
// orari coerenti col fuso italiano (CEST in estate, CET in inverno).
const fmtData = (iso: string) =>
  new Date(iso).toLocaleString('it-IT', {
    timeZone: 'Europe/Rome',
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
const fmtSoloData = (iso: string) =>
  new Date(iso).toLocaleDateString('it-IT', {
    timeZone: 'Europe/Rome',
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
---
<BaseLayout
  title="Dashboard Admin — Sherlock"
  description="Statistiche d'uso del backend AI e abbonamenti"
>
  <main class="notranslate px-5 py-10 max-w-6xl mx-auto" translate="no">
    <header class="flex items-start justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-extrabold text-white">Dashboard Admin <span class="text-gold-400">— Sherlock</span></h1>
        <p class="text-navy-300 text-sm mt-1">Statistiche d'uso del backend AI e abbonamenti</p>
        <p class="text-navy-400 text-xs mt-1">Sessione: <span class="text-gold-400">{adminEmail}</span> · <a href="/api/auth/logout" class="underline hover:text-gold-300">esci</a></p>
      </div>
    </header>

    <section class="mb-8">
      <div class="rounded-2xl border border-navy-700 bg-gradient-to-br from-navy-900 via-navy-950 to-navy-900 p-6 shadow-2xl">
        <div class="flex items-start justify-between gap-6 mb-6">
          <div>
            <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">Stato generale</div>
            <div class="text-3xl font-extrabold text-white mt-1">Sherlock — polso rapido</div>
            <div class="text-[11px] text-navy-500 mt-1">Aggiornato {dataHealthNow} · una card = un aspetto · colpo d'occhio</div>
          </div>
          <div class="flex items-center gap-4">
            <div class="relative w-24 h-24 flex-shrink-0">
              <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90">
                <circle cx="50" cy="50" r="42" stroke-width="8" fill="none" class="stroke-navy-800"></circle>
                <circle
                  cx="50" cy="50" r="42" stroke-width="8" fill="none"
                  class={scoreRing}
                  stroke-linecap="round"
                  stroke-dasharray={`${ringDash} 264`}
                ></circle>
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <div class={`text-2xl font-extrabold ${scoreColor}`}>{scoreAggregato}</div>
                <div class="text-[8px] uppercase tracking-widest text-navy-400">/ 100</div>
              </div>
            </div>
            <div class="text-right">
              <div class="text-[10px] uppercase tracking-widest text-navy-400">Diagnosi</div>
              <div class={`text-lg font-extrabold uppercase ${scoreColor}`}>{scoreLabel}</div>
              <div class="text-[10px] text-navy-500 mt-1 max-w-[140px]">media delle 5 dimensioni</div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-5 gap-3">
          {dimensioni.map((d) => {
            const c = tileColor(d.score);
            return (
              <div class={`rounded-xl border ${c.border} bg-gradient-to-b ${c.bg} p-4 flex flex-col items-center text-center`}>
                <div class="text-2xl mb-1" aria-hidden="true">{dimensionIcon(d.label)}</div>
                <div class="text-[10px] uppercase tracking-widest text-navy-300 font-bold">{d.label}</div>
                <div class={`text-2xl font-extrabold mt-1 ${c.num}`}>{d.big}</div>
                <div class="text-[10px] text-navy-500 mt-0.5 leading-tight min-h-[24px]">{d.note}</div>
                <div class="w-full h-1.5 bg-navy-800 rounded-full mt-2 overflow-hidden">
                  <div class={`h-full ${c.bar} rounded-full transition-all`} style={`width:${d.score}%`}></div>
                </div>
                <div class="flex items-center justify-between w-full mt-2 text-[10px]">
                  <span class="text-navy-500 font-mono">{d.score.toFixed(0)}</span>
                  <span class={`font-bold text-base leading-none ${trendColor(d.trend)}`} title={d.trend === 'up' ? 'in crescita' : d.trend === 'down' ? 'in calo' : d.trend === 'flat' ? 'stabile' : 'dati insufficienti'}>{trendGlyph(d.trend)}</span>
                </div>
              </div>
            );
          })}
        </div>

        <div class="mt-4 text-[11px] text-navy-500 leading-relaxed">
          <strong class="text-navy-300">Come leggere</strong> — colore card = stato (verde ok, ambra da monitorare, rosso critico) · numero grande = misura primaria · barra = punteggio 0-100 · freccia = tendenza dei giorni recenti vs precedenti (↗ crescita &gt;15%, ↘ calo &gt;15%, ↔ stabile). Nessun singolo indicatore va guardato da solo: il cerchio centrale è la media.
        </div>
      </div>
    </section>

    <section class="mb-6">
      <div class="flex items-baseline justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">Utilizzo API</div>
        <div class="text-[10px] text-navy-500">i totali includono tentativi falliti e bloccati</div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-6 gap-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Richieste analisi</div>
          <div class="text-3xl font-extrabold text-white mt-1">{stats.analisiTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            err: <span class="text-red-300">{stats.erroriAnalizzaTotali}</span> · bloc: <span class="text-amber-300">{stats.bloccatiAnalizzaTotali}</span>
          </div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Analisi oggi</div>
          <div class="text-3xl font-extrabold text-gold-400 mt-1">{stats.analisiOggi}</div>
          <div class="text-[10px] text-navy-500 mt-1">tentate (ok + err + bloc)</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Richieste lettera</div>
          <div class="text-3xl font-extrabold text-white mt-1">{stats.lettereTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            err: <span class="text-red-300">{stats.erroriLetteraTotali}</span> · bloc: <span class="text-amber-300">{stats.bloccatiLetteraTotali}</span>
          </div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Richieste compara</div>
          <div class="text-3xl font-extrabold text-white mt-1">{stats.comparaTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            err: <span class="text-red-300">{stats.erroriComparaTotali}</span> · bloc: <span class="text-amber-300">{stats.bloccatiComparaTotali}</span>
          </div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Bloccate (tot.)</div>
          <div class="text-3xl font-extrabold text-amber-300 mt-1">{stats.bloccatiTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            an: {stats.bloccatiAnalizzaTotali} · le: {stats.bloccatiLetteraTotali} · cp: {stats.bloccatiComparaTotali}{bloccatiPreSplit > 0 && (<> · pre: {bloccatiPreSplit}</>)}
          </div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Errori AI (tot.)</div>
          <div class="text-3xl font-extrabold text-red-400 mt-1">{stats.erroriTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            an: {stats.erroriAnalizzaTotali} · le: {stats.erroriLetteraTotali} · cp: {stats.erroriComparaTotali}{erroriPreSplit > 0 && (<> · pre: {erroriPreSplit}</>)}
          </div>
        </div>
      </div>
      {(erroriPreSplit > 0 || bloccatiPreSplit > 0) && (
        <div class="text-[10px] text-navy-500 mt-2">
          "pre" = eventi registrati prima dello split per tipo (counter introdotti il 29/06/2026); restano contati nei totali.
        </div>
      )}
    </section>

    <section class="mb-6">
      <div class="flex items-baseline justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">App Sherlock — Play Console</div>
        <div class="text-[10px] text-navy-500">Cache 6h · medie su 28 giorni · <a href="/admin?refresh=play" class="underline hover:text-gold-300">forza refresh</a></div>
      </div>

      {stabError && (
        <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 p-3 mb-3 text-xs text-amber-200">
          Stabilit&agrave; non disponibile: <span class="font-mono">{stabError}</span>
        </div>
      )}

      <div class="grid grid-cols-2 gap-3 mb-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Crash rate (28gg)</div>
          <div class={`text-3xl font-extrabold mt-1 ${stab && stab.crashRate28gg !== null && stab.crashRate28gg > 1 ? 'text-red-400' : 'text-emerald-400'}`}>
            {stab ? fmtPct(stab.crashRate28gg) : '—'}
          </div>
          <div class="text-[10px] text-navy-500 mt-1">ultimo: {stab ? fmtPct(stab.crashRateOggi) : '—'}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">ANR rate (28gg)</div>
          <div class={`text-3xl font-extrabold mt-1 ${stab && stab.anrRate28gg !== null && stab.anrRate28gg > 0.47 ? 'text-red-400' : 'text-emerald-400'}`}>
            {stab ? fmtPct(stab.anrRate28gg) : '—'}
          </div>
          <div class="text-[10px] text-navy-500 mt-1">ultimo: {stab ? fmtPct(stab.anrRateOggi) : '—'}</div>
        </div>
      </div>
      <div class="text-[11px] text-navy-500">
        Fonte: Play Developer Reporting API (installazioni e disinstall dal bucket CSV rimossi: il pipeline è fermo <strong>upstream lato Google</strong> dal 21 giu 2026 e non è risolvibile da noi. Cronologia in <a href="/admin/play-diag" class="underline hover:text-gold-300">diagnostica</a>).
      </div>
    </section>

    <section class="mb-6">
      <div class="flex items-baseline justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">Analytics web — 7 giorni</div>
        <div class="text-[10px] text-navy-500">Cache 1h · <a href="/admin?refresh=ga4" class="underline hover:text-gold-300">forza refresh</a> · <a href="https://analytics.google.com/analytics/web/" target="_blank" rel="noopener" class="underline hover:text-gold-300">apri GA4</a></div>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        {profili.map(({ titolo, codice, res }) => {
          const ok = 'utenti7gg' in res ? res : null;
          const err = 'errore' in res ? res.errore : undefined;
          const maxU = ok ? Math.max(1, ...ok.serieUtenti.map((g) => g.utenti)) : 1;
          return (
            <div class="rounded-xl border border-navy-700 bg-navy-900 p-5">
              <div class="flex items-baseline justify-between mb-3">
                <div>
                  <div class="text-sm font-bold text-white">{titolo}</div>
                  <div class="text-[10px] text-navy-500 font-mono">{codice}{ok ? ` · property ${ok.propertyId}` : ''}</div>
                </div>
                {ok && <div class="text-[10px] text-emerald-400">● live</div>}
              </div>

              {err ? (
                <div class="rounded-lg border border-amber-500/40 bg-amber-500/10 p-3 text-[11px] text-amber-200 leading-relaxed">
                  <span class="font-bold">Non disponibile.</span><br />
                  <span class="font-mono text-[10px]">{err}</span>
                </div>
              ) : ok && (
                <>
                  <div class="grid grid-cols-4 gap-2 mb-4">
                    <div>
                      <div class="text-[10px] text-navy-400 uppercase tracking-wider">Utenti oggi</div>
                      <div class="text-xl font-extrabold text-emerald-400">{fmtNum(ok.utentiOggi)}</div>
                    </div>
                    <div>
                      <div class="text-[10px] text-navy-400 uppercase tracking-wider">Utenti 7gg</div>
                      <div class="text-xl font-extrabold text-white">{fmtNum(ok.utenti7gg)}</div>
                    </div>
                    <div>
                      <div class="text-[10px] text-navy-400 uppercase tracking-wider">Pageviews</div>
                      <div class="text-xl font-extrabold text-white">{fmtNum(ok.pageviews7gg)}</div>
                    </div>
                    <div>
                      <div class="text-[10px] text-navy-400 uppercase tracking-wider">Sessioni</div>
                      <div class="text-xl font-extrabold text-white">{fmtNum(ok.sessioni7gg)}</div>
                    </div>
                  </div>

                  {ok.serieUtenti.length > 0 && (
                    <div class="mb-4">
                      <div class="text-[10px] text-navy-500 mb-2">utenti attivi per giorno</div>
                      <div class="flex gap-1 items-end" style="min-height:60px">
                        {ok.serieUtenti.map((g) => {
                          const h = Math.round((g.utenti / maxU) * 100);
                          return (
                            <div class="flex-1 flex flex-col items-center gap-0.5" title={`${g.giorno}: ${g.utenti} utenti, ${g.pageviews} pageviews`}>
                              <div class="text-[8px] text-navy-500 font-mono">{g.utenti}</div>
                              <div class="w-full rounded-t bg-gradient-to-t from-gold-500 to-gold-300" style={`height:${Math.max(h, 2)}px`}></div>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  )}

                  <div class="grid grid-cols-1 gap-3">
                    {ok.topPagine.length > 0 && (
                      <div>
                        <div class="text-[10px] text-navy-500 uppercase tracking-wider mb-1">Top pagine</div>
                        <ul class="space-y-0.5 text-[11px] font-mono">
                          {ok.topPagine.slice(0, 5).map((p) => (
                            <li class="flex justify-between gap-2">
                              <span class="text-navy-200 truncate">{p.path || '/'}</span>
                              <span class="text-white flex-shrink-0">{fmtNum(p.views)}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                    {ok.topEventi.length > 0 && (
                      <div>
                        <div class="text-[10px] text-navy-500 uppercase tracking-wider mb-1">Top eventi</div>
                        <ul class="space-y-0.5 text-[11px] font-mono">
                          {ok.topEventi.slice(0, 5).map((ev) => (
                            <li class="flex justify-between gap-2">
                              <span class="text-navy-200 truncate">{ev.nome}</span>
                              <span class="text-white flex-shrink-0">{fmtNum(ev.occorrenze)}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>
                </>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <section class="mb-6">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Abbonamenti PayPal</div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Abbonati attivi</div>
          <div class="text-3xl font-extrabold text-emerald-400 mt-1">{abb.attivi}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Abbonamenti totali</div>
          <div class="text-3xl font-extrabold text-white mt-1">{abb.totali}</div>
        </div>
        <div class="rounded-xl border border-gold-400/40 bg-gradient-to-br from-navy-900 to-navy-800 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Ricavo totale</div>
          <div class="text-3xl font-extrabold text-gold-400 mt-1">{ricavoEuro} €</div>
        </div>
      </div>
    </section>

    <section class="mb-6">
      <div class="flex items-baseline justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">Pass Pro a vita (Founder)</div>
        <div class="text-[10px] text-navy-500">Contatore KV live · fonte: <span class="font-mono">count:founder:venduti</span></div>
      </div>
      <div class="rounded-xl border border-gold-400/40 bg-gradient-to-br from-navy-900 to-navy-800 p-4">
        <div class="flex items-baseline justify-between gap-4 mb-3">
          <div>
            <div class="text-xs text-navy-400 uppercase tracking-widest">Founder venduti</div>
            <div class="text-3xl font-extrabold text-gold-400 mt-1">
              {founderVenduti} <span class="text-navy-500 text-lg font-bold">/ {FOUNDER_MAX}</span>
            </div>
          </div>
          <div class="text-right">
            <div class="text-xs text-navy-400 uppercase tracking-widest">Rimanenti</div>
            <div class={`text-3xl font-extrabold mt-1 ${founderRimanenti === 0 ? 'text-red-400' : founderRimanenti < 10 ? 'text-amber-300' : 'text-emerald-400'}`}>{founderRimanenti}</div>
          </div>
        </div>
        <div class="w-full h-2 bg-navy-800 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-gold-500 to-gold-300" style={`width:${founderPctVenduto}%`}></div>
        </div>
        <div class="text-[10px] text-navy-500 mt-2 flex justify-between">
          <span>{founderPctVenduto.toFixed(1)}% venduto</span>
          <span>Chiude a {FOUNDER_MAX} — poi solo mensile/semestrale/annuale</span>
        </div>
      </div>
    </section>

    <section class="mb-6">
      <div class="flex items-baseline justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">PayPal Processing — health check (audit R4)</div>
        <div class="text-[10px] text-navy-500">
          Idempotenza + crash recovery · fonte: <span class="font-mono">paypal_proc:*</span>
          {ppProc.ultimoAggiornamento && <> · ultimo update: {fmtData(ppProc.ultimoAggiornamento)}</>}
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Record totali</div>
          <div class="text-3xl font-extrabold text-white mt-1">{ppProc.total}</div>
          <div class="text-[10px] text-navy-500 mt-1">tutti gli orderId processati</div>
        </div>
        <div class="rounded-xl border border-emerald-500/30 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Completed</div>
          <div class="text-3xl font-extrabold text-emerald-400 mt-1">{ppProc.completed}</div>
          <div class="text-[10px] text-navy-500 mt-1">codice emesso + email + GA4</div>
        </div>
        <div class="rounded-xl border border-amber-500/30 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Processing</div>
          <div class={`text-3xl font-extrabold mt-1 ${ppProc.processing > 0 ? 'text-amber-300' : 'text-navy-400'}`}>{ppProc.processing}</div>
          <div class={`text-[10px] mt-1 ${ppProc.stuckProcessing > 0 ? 'text-red-300' : 'text-navy-500'}`}>
            {ppProc.stuckProcessing > 0 ? `${ppProc.stuckProcessing} stuck > 10 min` : 'in-flight normale'}
          </div>
        </div>
        <div class="rounded-xl border border-red-500/30 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Failed</div>
          <div class={`text-3xl font-extrabold mt-1 ${ppProc.failed > 0 ? 'text-red-400' : 'text-navy-400'}`}>{ppProc.failed}</div>
          <div class="text-[10px] text-navy-500 mt-1">capture o status non ok</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">captureId coverage</div>
          <div class={`text-3xl font-extrabold mt-1 ${ppCaptureCoverage >= 95 ? 'text-emerald-400' : ppCaptureCoverage >= 70 ? 'text-amber-300' : 'text-navy-500'}`}>
            {ppProc.completed > 0 ? `${ppCaptureCoverage.toFixed(0)}%` : '—'}
          </div>
          <div class="text-[10px] text-navy-500 mt-1">
            {ppProc.withCaptureId}/{ppProc.completed} completed con captureId
          </div>
        </div>
      </div>
      {ppProc.stuckProcessing > 0 && (
        <div class="mt-3 rounded-lg border border-red-500/40 bg-red-500/10 p-3 text-xs text-red-200">
          ⚠️ <strong>{ppProc.stuckProcessing} record in stato <code class="font-mono">processing</code> da &gt; 10 min</strong>: possibile crash mid-flow. La logica di recovery in <code class="font-mono">capture-order.ts</code> li completa alla prossima chiamata dell'utente; se il cliente non torna, il codice non viene mai emesso. Considera un cron di reconciliation.
        </div>
      )}
      {ppProc.total === 0 && (
        <div class="mt-3 rounded-lg border border-navy-700 bg-navy-900/50 p-3 text-xs text-navy-400">
          Nessun record ancora processato (i processing record sono nati con l'audit R4 del 13/07/2026). I record precedenti restano nell'indice legacy <code class="font-mono">paypal_order:*</code> e continuano a funzionare per idempotenza.
        </div>
      )}
    </section>

    <section class="mb-6">
      <div class="flex items-baseline justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">Config check — audit R4</div>
        <div class="text-[10px] text-navy-500">Verifica env vars server-side (nessun valore mostrato)</div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div class={`rounded-xl border p-4 ${streamsConfigurati.web ? 'border-emerald-500/30 bg-navy-900' : 'border-red-500/30 bg-red-500/5'}`}>
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1">
              <div class="text-xs text-navy-400 uppercase tracking-widest">Stream GA4 Web</div>
              <div class="text-sm font-mono text-navy-300 mt-1">GA4_WEB_MEASUREMENT_ID + GA4_WEB_API_SECRET</div>
              <div class="text-[10px] text-navy-500 mt-2">
                Proprietà "Sherlock Polizze Web" collegata a Google Ads. Riceve <code class="font-mono text-navy-300">purchase</code>, <code class="font-mono text-navy-300">analysis_complete</code>, <code class="font-mono text-navy-300">pro_status_lookup_success</code>, <code class="font-mono text-navy-300">checkout_started</code>, <code class="font-mono text-navy-300">paypal_redirect</code>.
              </div>
            </div>
            <div class={`text-2xl font-extrabold ${streamsConfigurati.web ? 'text-emerald-400' : 'text-red-400'}`}>{streamsConfigurati.web ? '✓' : '✗'}</div>
          </div>
          {!streamsConfigurati.web && (
            <div class="mt-3 text-[11px] text-red-200 leading-relaxed">
              <strong>Non configurato.</strong> <code class="font-mono">ga4TrackServer</code> è no-op per lo stream 'web': Google Ads non riceve conversioni server-side. Configura entrambe le env in Vercel → Production/Preview.
            </div>
          )}
        </div>
        <div class={`rounded-xl border p-4 ${streamsConfigurati.firebase ? 'border-emerald-500/30 bg-navy-900' : 'border-amber-500/30 bg-amber-500/5'}`}>
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1">
              <div class="text-xs text-navy-400 uppercase tracking-widest">Stream GA4 Firebase</div>
              <div class="text-sm font-mono text-navy-300 mt-1">GA4_FIREBASE_MEASUREMENT_ID + GA4_FIREBASE_API_SECRET</div>
              <div class="text-[10px] text-navy-500 mt-2">
                Proprietà Firebase legacy (project sherlock-6f88c). Riceve <code class="font-mono text-navy-300">play_billing_verified</code> quando l'app Android trasmetterà <span class="italic">app_instance_id</span> via bridge. Fallback retrocompat: <code class="font-mono">PUBLIC_FIREBASE_MEASUREMENT_ID</code> + <code class="font-mono">GA4_API_SECRET</code>.
              </div>
            </div>
            <div class={`text-2xl font-extrabold ${streamsConfigurati.firebase ? 'text-emerald-400' : 'text-amber-300'}`}>{streamsConfigurati.firebase ? '✓' : '⚠'}</div>
          </div>
          {!streamsConfigurati.firebase && (
            <div class="mt-3 text-[11px] text-amber-200 leading-relaxed">
              Non configurato (né env dedicate né fallback legacy). Play Billing events server-side no-op.
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-navy-700 bg-navy-900 p-5 mb-8">
      <div class="text-sm text-navy-200 font-bold mb-4">Analisi per giorno — ultimi 7 giorni</div>
      <div class="grid grid-cols-7 gap-2 items-end" style="min-height:160px">
        {stats.perGiorno.map((g) => {
          const h = Math.round((g.analisi / maxAnalisi) * 130);
          return (
            <div class="flex flex-col items-center gap-1">
              <div class="text-[10px] text-navy-400 font-semibold">{g.analisi}</div>
              <div class="w-full rounded-t bg-gradient-to-t from-gold-400 to-amber-200" style={`height:${Math.max(h, 2)}px`} title={`${g.giorno}: ${g.analisi} analisi`}></div>
              <div class="text-[10px] text-navy-400 mt-1">{oggiBreve(g.giorno)}</div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="mb-8">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Abbonati ({abb.totali})</div>
      <div class="rounded-xl border border-navy-700 bg-navy-900 overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="text-navy-400 uppercase tracking-widest text-[10px] border-b border-navy-800">
              <th class="text-left p-3">Data</th>
              <th class="text-left p-3">Email</th>
              <th class="text-left p-3">Stato</th>
              <th class="text-left p-3">Piano</th>
              <th class="text-right p-3">Importo</th>
              <th class="text-left p-3">Scadenza</th>
              <th class="text-left p-3">Fonte / Order ID</th>
            </tr>
          </thead>
          <tbody>
            {abb.records.length === 0 ? (
              <tr><td colspan="7" class="p-6 text-center text-navy-400">Nessun abbonato ancora.</td></tr>
            ) : abb.records.map((r) => {
              const attivo = new Date(r.dataScadenza) > new Date();
              const importo = ({ mensile: '2,99 €', semestrale: '7,99 €', annuale: '14,99 €', singolo: '3,99 €', founder: '19,90 €' } as const)[r.piano];
              return (
                <tr class="border-b border-navy-800 last:border-0">
                  <td class="p-3 text-navy-200">{fmtSoloData(r.dataEmissione)}</td>
                  <td class="p-3 text-navy-100">{r.email}</td>
                  <td class="p-3">
                    {attivo
                      ? <span class="inline-block bg-emerald-500/15 text-emerald-300 border border-emerald-500/30 rounded px-2 py-0.5 text-[10px] font-bold uppercase">Attivo</span>
                      : <span class="inline-block bg-red-500/15 text-red-300 border border-red-500/30 rounded px-2 py-0.5 text-[10px] font-bold uppercase">Scaduto</span>
                    }
                  </td>
                  <td class="p-3 capitalize text-navy-200">{r.piano}</td>
                  <td class="p-3 text-right text-gold-300 font-bold">{importo}</td>
                  <td class="p-3 text-navy-300">{fmtSoloData(r.dataScadenza)}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">
                    {r.fonte === 'play' ? (
                      <><span class="inline-block bg-emerald-500/15 text-emerald-300 rounded px-1.5 py-0.5 text-[9px] font-bold mr-1.5 align-middle">PLAY</span>{r.playOrderId ?? r.codice}</>
                    ) : (
                      <><span class="inline-block bg-blue-500/15 text-blue-300 rounded px-1.5 py-0.5 text-[9px] font-bold mr-1.5 align-middle">PAYPAL</span>{r.paypalOrderId ?? r.codice}</>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-12">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Richieste API recenti (ultime {eventi.length})</div>
      <div class="rounded-xl border border-navy-700 bg-navy-900 overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="text-navy-400 uppercase tracking-widest text-[10px] border-b border-navy-800">
              <th class="text-left p-3">Timestamp</th>
              <th class="text-left p-3">Tipo</th>
              <th class="text-left p-3">Esito</th>
              <th class="text-left p-3">Errore / Warning</th>
              <th class="text-left p-3">Request ID</th>
              <th class="text-left p-3">IP</th>
              <th class="text-right p-3">ms</th>
            </tr>
          </thead>
          <tbody>
            {eventi.length === 0 ? (
              <tr><td colspan="7" class="p-6 text-center text-navy-400">Nessuna chiamata API ancora registrata.</td></tr>
            ) : eventi.map((e) => {
              const colore = e.esito === 'ok'
                ? 'bg-emerald-500/15 text-emerald-300 border-emerald-500/30'
                : e.esito === 'bloccato'
                  ? 'bg-amber-500/15 text-amber-300 border-amber-500/30'
                  : 'bg-red-500/15 text-red-300 border-red-500/30';
              return (
                <tr class="border-b border-navy-800 last:border-0">
                  <td class="p-3 text-navy-300">{fmtData(e.ts)}</td>
                  <td class="p-3 text-navy-200">{e.tipo}</td>
                  <td class="p-3">
                    <span class={`inline-block rounded px-2 py-0.5 text-[10px] font-bold uppercase border ${colore}`}>{e.esito}</span>
                  </td>
                  <td class="p-3 text-navy-300 max-w-xs truncate" title={e.errore ?? ''}>{e.errore ?? '—'}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">{e.requestId}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">{e.ip}</td>
                  <td class="p-3 text-right text-navy-200">{e.ms}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</BaseLayout>
