---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { leggiStats } from '../../lib/log';
import { leggiAbbonati } from '../../lib/storage';
import { leggiUltimiEventi } from '../../lib/log';
import { leggiStabilitaApp, leggiUsoApp, invalidaCachePlay } from '../../lib/play';

// /admin?refresh=play forza il refresh della cache Play (bypass 6h TTL).
if (Astro.url.searchParams.get('refresh') === 'play') {
  await invalidaCachePlay();
}

// Le chiamate Play possono fallire (SA non configurato, bucket non
// accessibile): le gestisco con allSettled per non rompere la dashboard.
const [stats, abb, eventi, stabRes, usoRes] = await Promise.all([
  leggiStats(),
  leggiAbbonati(),
  leggiUltimiEventi(50),
  leggiStabilitaApp().catch((e: any) => ({ errore: String(e?.message ?? e) }) as any),
  leggiUsoApp().catch((e: any) => ({ errore: String(e?.message ?? e), installazioniPerGiorno: [], acquisizioni28gg: 0, mau: null, primeAperture28gg: null, ultimoGiorno: null, giorniRitardo: null }) as any),
]);
const stab = ('crashRate28gg' in stabRes ? stabRes : null) as Awaited<ReturnType<typeof leggiStabilitaApp>> | null;
const stabError = (stabRes as any).errore as string | undefined;
const uso = usoRes as Awaited<ReturnType<typeof leggiUsoApp>>;
const maxInst = Math.max(1, ...uso.installazioniPerGiorno.map((g) => g.nuove));
const fmtPct = (n: number | null) => n === null ? '—' : `${n.toFixed(2)} %`;

const adminEmail = Astro.locals.adminEmail ?? '';
const ricavoEuro = (abb.ricavoEuroCent / 100).toFixed(2).replace('.', ',');

const maxAnalisi = Math.max(1, ...stats.perGiorno.map((g) => g.analisi));
const oggiBreve = (g: string) => {
  const d = new Date(g);
  return d.toLocaleDateString('it-IT', { day: '2-digit', month: 'short' });
};

// Errori/bloccati per tipo: i counter sono stati introdotti dopo il go-live.
// Il "residuo" è la quota di errori storici aggregati prima dello split, che
// non possiamo riassegnare a un tipo specifico — la mostriamo come "pre-split"
// invece di gonfiare arbitrariamente una delle due colonne.
const erroriPreSplit = Math.max(
  0,
  stats.erroriTotali - stats.erroriAnalizzaTotali - stats.erroriLetteraTotali - stats.erroriComparaTotali,
);
const bloccatiPreSplit = Math.max(
  0,
  stats.bloccatiTotali - stats.bloccatiAnalizzaTotali - stats.bloccatiLetteraTotali - stats.bloccatiComparaTotali,
);

// Considero "stale" il dato Play se il più recente è > 3 giorni fa: il batch
// Play di solito ha 1-2 giorni di ritardo, oltre i 3 c'è qualcosa che non gira
// (bucket non aggiornato, SA che ha perso i permessi, ecc.).
const playStale = (uso.giorniRitardo ?? 0) > 3;
const fmtDataIt = (g: string) =>
  new Date(`${g}T12:00:00Z`).toLocaleDateString('it-IT', { day: '2-digit', month: 'short' });

// Vercel functions girano in UTC; forzo Europe/Rome così la dashboard mostra
// orari coerenti col fuso italiano (CEST in estate, CET in inverno).
const fmtData = (iso: string) =>
  new Date(iso).toLocaleString('it-IT', {
    timeZone: 'Europe/Rome',
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
const fmtSoloData = (iso: string) =>
  new Date(iso).toLocaleDateString('it-IT', {
    timeZone: 'Europe/Rome',
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
---
<BaseLayout
  title="Dashboard Admin — Sherlock"
  description="Statistiche d'uso del backend AI e abbonamenti"
>
  <main class="notranslate px-5 py-10 max-w-6xl mx-auto" translate="no">
    <header class="flex items-start justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-extrabold text-white">Dashboard Admin <span class="text-gold-400">— Sherlock</span></h1>
        <p class="text-navy-300 text-sm mt-1">Statistiche d'uso del backend AI e abbonamenti</p>
        <p class="text-navy-400 text-xs mt-1">Sessione: <span class="text-gold-400">{adminEmail}</span> · <a href="/api/auth/logout" class="underline hover:text-gold-300">esci</a></p>
      </div>
    </header>

    <section class="mb-6">
      <div class="flex items-baseline justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">Utilizzo API</div>
        <div class="text-[10px] text-navy-500">i totali includono tentativi falliti e bloccati</div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-6 gap-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Richieste analisi</div>
          <div class="text-3xl font-extrabold text-white mt-1">{stats.analisiTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            err: <span class="text-red-300">{stats.erroriAnalizzaTotali}</span> · bloc: <span class="text-amber-300">{stats.bloccatiAnalizzaTotali}</span>
          </div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Analisi oggi</div>
          <div class="text-3xl font-extrabold text-gold-400 mt-1">{stats.analisiOggi}</div>
          <div class="text-[10px] text-navy-500 mt-1">tentate (ok + err + bloc)</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Richieste lettera</div>
          <div class="text-3xl font-extrabold text-white mt-1">{stats.lettereTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            err: <span class="text-red-300">{stats.erroriLetteraTotali}</span> · bloc: <span class="text-amber-300">{stats.bloccatiLetteraTotali}</span>
          </div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Richieste compara</div>
          <div class="text-3xl font-extrabold text-white mt-1">{stats.comparaTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            err: <span class="text-red-300">{stats.erroriComparaTotali}</span> · bloc: <span class="text-amber-300">{stats.bloccatiComparaTotali}</span>
          </div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Bloccate (tot.)</div>
          <div class="text-3xl font-extrabold text-amber-300 mt-1">{stats.bloccatiTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            an: {stats.bloccatiAnalizzaTotali} · le: {stats.bloccatiLetteraTotali} · cp: {stats.bloccatiComparaTotali}{bloccatiPreSplit > 0 && (<> · pre: {bloccatiPreSplit}</>)}
          </div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Errori AI (tot.)</div>
          <div class="text-3xl font-extrabold text-red-400 mt-1">{stats.erroriTotali}</div>
          <div class="text-[10px] text-navy-500 mt-1">
            an: {stats.erroriAnalizzaTotali} · le: {stats.erroriLetteraTotali} · cp: {stats.erroriComparaTotali}{erroriPreSplit > 0 && (<> · pre: {erroriPreSplit}</>)}
          </div>
        </div>
      </div>
      {(erroriPreSplit > 0 || bloccatiPreSplit > 0) && (
        <div class="text-[10px] text-navy-500 mt-2">
          "pre" = eventi registrati prima dello split per tipo (counter introdotti il 29/06/2026); restano contati nei totali.
        </div>
      )}
    </section>

    <section class="mb-6">
      <div class="flex items-baseline justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-navy-400 font-bold">App Sherlock — Play Console</div>
        <div class="text-[10px] text-navy-500">Cache 6h · medie su 28 giorni · <a href="/admin?refresh=play" class="underline hover:text-gold-300">forza refresh</a></div>
      </div>

      {stabError && (
        <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 p-3 mb-3 text-xs text-amber-200">
          Stabilit&agrave; non disponibile: <span class="font-mono">{stabError}</span>
        </div>
      )}

      {playStale && uso.ultimoGiorno && (
        <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 p-3 mb-3 text-xs text-amber-200">
          <span class="font-bold">Dati installazioni in ritardo:</span> ultimo CSV Play disponibile {fmtDataIt(uso.ultimoGiorno)} (<span class="font-mono">{uso.giorniRitardo}</span> giorni fa). I valori &quot;28gg&quot; qui sotto si riferiscono alla finestra dei dati disponibili, non agli ultimi 28 giorni di calendario. Se il ritardo persiste, verifica i permessi del Service Account sul bucket Play o forza un <a href="/admin?refresh=play" class="underline hover:text-gold-300">refresh</a>.
        </div>
      )}

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Crash rate (28gg)</div>
          <div class={`text-3xl font-extrabold mt-1 ${stab && stab.crashRate28gg !== null && stab.crashRate28gg > 1 ? 'text-red-400' : 'text-emerald-400'}`}>
            {stab ? fmtPct(stab.crashRate28gg) : '—'}
          </div>
          <div class="text-[10px] text-navy-500 mt-1">ultimo: {stab ? fmtPct(stab.crashRateOggi) : '—'}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">ANR rate (28gg)</div>
          <div class={`text-3xl font-extrabold mt-1 ${stab && stab.anrRate28gg !== null && stab.anrRate28gg > 0.47 ? 'text-red-400' : 'text-emerald-400'}`}>
            {stab ? fmtPct(stab.anrRate28gg) : '—'}
          </div>
          <div class="text-[10px] text-navy-500 mt-1">ultimo: {stab ? fmtPct(stab.anrRateOggi) : '—'}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Installazioni nette {uso.ultimoGiorno ? `(fino al ${fmtDataIt(uso.ultimoGiorno)})` : '(28gg)'}</div>
          <div class="text-3xl font-extrabold text-white mt-1">{uso.acquisizioni28gg}</div>
          <div class="text-[10px] text-navy-500 mt-1">install &minus; disinstall · finestra {uso.installazioniPerGiorno.length} gg</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Disinstall. {uso.ultimoGiorno ? `(fino al ${fmtDataIt(uso.ultimoGiorno)})` : '(28gg)'}</div>
          <div class="text-3xl font-extrabold text-amber-300 mt-1">
            {uso.installazioniPerGiorno.reduce((s, g) => s + g.disinstall, 0)}
          </div>
          <div class="text-[10px] text-navy-500 mt-1">finestra {uso.installazioniPerGiorno.length} gg</div>
        </div>
      </div>

      {uso.errore ? (
        <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 p-3 text-xs text-amber-200">
          Statistiche installazioni non ancora disponibili: <span class="font-mono">{uso.errore}</span>.
          I permessi sul bucket Play possono impiegare fino a 24h per propagarsi.
        </div>
      ) : uso.installazioniPerGiorno.length === 0 ? (
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-5 text-xs text-navy-400">
          Nessun dato di installazioni disponibile ancora.
        </div>
      ) : (
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-5">
          <div class="text-xs text-navy-200 font-bold mb-3">Installazioni per giorno — ultimi {uso.installazioniPerGiorno.length} giorni</div>
          <div class="flex gap-1 items-end" style="min-height:120px">
            {uso.installazioniPerGiorno.map((g) => {
              const h = Math.round((g.nuove / maxInst) * 100);
              return (
                <div class="flex-1 flex flex-col items-center gap-1" title={`${g.giorno}: +${g.nuove} install, -${g.disinstall} disinstall`}>
                  <div class="text-[9px] text-navy-400 font-semibold">{g.nuove}</div>
                  <div class="w-full rounded-t bg-gradient-to-t from-emerald-500 to-emerald-300" style={`height:${Math.max(h, 2)}px`}></div>
                </div>
              );
            })}
          </div>
          <div class="text-[10px] text-navy-500 mt-2 text-right">primo: {uso.installazioniPerGiorno[0]?.giorno} · ultimo: {uso.installazioniPerGiorno.at(-1)?.giorno}</div>
        </div>
      )}
    </section>

    <section class="mb-6">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Abbonamenti PayPal</div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Abbonati attivi</div>
          <div class="text-3xl font-extrabold text-emerald-400 mt-1">{abb.attivi}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Abbonamenti totali</div>
          <div class="text-3xl font-extrabold text-white mt-1">{abb.totali}</div>
        </div>
        <div class="rounded-xl border border-gold-400/40 bg-gradient-to-br from-navy-900 to-navy-800 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Ricavo totale</div>
          <div class="text-3xl font-extrabold text-gold-400 mt-1">{ricavoEuro} €</div>
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-navy-700 bg-navy-900 p-5 mb-8">
      <div class="text-sm text-navy-200 font-bold mb-4">Analisi per giorno — ultimi 7 giorni</div>
      <div class="grid grid-cols-7 gap-2 items-end" style="min-height:160px">
        {stats.perGiorno.map((g) => {
          const h = Math.round((g.analisi / maxAnalisi) * 130);
          return (
            <div class="flex flex-col items-center gap-1">
              <div class="text-[10px] text-navy-400 font-semibold">{g.analisi}</div>
              <div class="w-full rounded-t bg-gradient-to-t from-gold-400 to-amber-200" style={`height:${Math.max(h, 2)}px`} title={`${g.giorno}: ${g.analisi} analisi`}></div>
              <div class="text-[10px] text-navy-400 mt-1">{oggiBreve(g.giorno)}</div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="mb-8">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Abbonati ({abb.totali})</div>
      <div class="rounded-xl border border-navy-700 bg-navy-900 overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="text-navy-400 uppercase tracking-widest text-[10px] border-b border-navy-800">
              <th class="text-left p-3">Data</th>
              <th class="text-left p-3">Email</th>
              <th class="text-left p-3">Stato</th>
              <th class="text-left p-3">Piano</th>
              <th class="text-right p-3">Importo</th>
              <th class="text-left p-3">Scadenza</th>
              <th class="text-left p-3">PayPal Order ID</th>
            </tr>
          </thead>
          <tbody>
            {abb.records.length === 0 ? (
              <tr><td colspan="7" class="p-6 text-center text-navy-400">Nessun abbonato ancora.</td></tr>
            ) : abb.records.map((r) => {
              const attivo = new Date(r.dataScadenza) > new Date();
              const importo = ({ mensile: '2,99 €', semestrale: '7,99 €', annuale: '14,99 €', singolo: '3,99 €', founder: '19,90 €' } as const)[r.piano];
              return (
                <tr class="border-b border-navy-800 last:border-0">
                  <td class="p-3 text-navy-200">{fmtSoloData(r.dataEmissione)}</td>
                  <td class="p-3 text-navy-100">{r.email}</td>
                  <td class="p-3">
                    {attivo
                      ? <span class="inline-block bg-emerald-500/15 text-emerald-300 border border-emerald-500/30 rounded px-2 py-0.5 text-[10px] font-bold uppercase">Attivo</span>
                      : <span class="inline-block bg-red-500/15 text-red-300 border border-red-500/30 rounded px-2 py-0.5 text-[10px] font-bold uppercase">Scaduto</span>
                    }
                  </td>
                  <td class="p-3 capitalize text-navy-200">{r.piano}</td>
                  <td class="p-3 text-right text-gold-300 font-bold">{importo}</td>
                  <td class="p-3 text-navy-300">{fmtSoloData(r.dataScadenza)}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">{r.paypalOrderId}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-12">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Richieste API recenti (ultime {eventi.length})</div>
      <div class="rounded-xl border border-navy-700 bg-navy-900 overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="text-navy-400 uppercase tracking-widest text-[10px] border-b border-navy-800">
              <th class="text-left p-3">Timestamp</th>
              <th class="text-left p-3">Tipo</th>
              <th class="text-left p-3">Esito</th>
              <th class="text-left p-3">Errore / Warning</th>
              <th class="text-left p-3">Request ID</th>
              <th class="text-left p-3">IP</th>
              <th class="text-right p-3">ms</th>
            </tr>
          </thead>
          <tbody>
            {eventi.length === 0 ? (
              <tr><td colspan="7" class="p-6 text-center text-navy-400">Nessuna chiamata API ancora registrata.</td></tr>
            ) : eventi.map((e) => {
              const colore = e.esito === 'ok'
                ? 'bg-emerald-500/15 text-emerald-300 border-emerald-500/30'
                : e.esito === 'bloccato'
                  ? 'bg-amber-500/15 text-amber-300 border-amber-500/30'
                  : 'bg-red-500/15 text-red-300 border-red-500/30';
              return (
                <tr class="border-b border-navy-800 last:border-0">
                  <td class="p-3 text-navy-300">{fmtData(e.ts)}</td>
                  <td class="p-3 text-navy-200">{e.tipo}</td>
                  <td class="p-3">
                    <span class={`inline-block rounded px-2 py-0.5 text-[10px] font-bold uppercase border ${colore}`}>{e.esito}</span>
                  </td>
                  <td class="p-3 text-navy-300 max-w-xs truncate" title={e.errore ?? ''}>{e.errore ?? '—'}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">{e.requestId}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">{e.ip}</td>
                  <td class="p-3 text-right text-navy-200">{e.ms}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</BaseLayout>
