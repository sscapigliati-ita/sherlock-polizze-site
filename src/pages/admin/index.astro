---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { leggiStats } from '../../lib/log';
import { leggiAbbonati } from '../../lib/storage';
import { leggiUltimiEventi } from '../../lib/log';

const [stats, abb, eventi] = await Promise.all([
  leggiStats(),
  leggiAbbonati(),
  leggiUltimiEventi(50),
]);

const adminEmail = Astro.locals.adminEmail ?? '';
const ricavoEuro = (abb.ricavoEuroCent / 100).toFixed(2).replace('.', ',');

const maxAnalisi = Math.max(1, ...stats.perGiorno.map((g) => g.analisi));
const oggiBreve = (g: string) => {
  const d = new Date(g);
  return d.toLocaleDateString('it-IT', { day: '2-digit', month: 'short' });
};

const fmtData = (iso: string) =>
  new Date(iso).toLocaleString('it-IT', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
const fmtSoloData = (iso: string) =>
  new Date(iso).toLocaleDateString('it-IT', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
---
<BaseLayout
  title="Dashboard Admin — Sherlock"
  description="Statistiche d'uso del backend AI e abbonamenti"
>
  <main class="px-5 py-10 max-w-6xl mx-auto">
    <header class="flex items-start justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-extrabold text-white">Dashboard Admin <span class="text-gold-400">— Sherlock</span></h1>
        <p class="text-navy-300 text-sm mt-1">Statistiche d'uso del backend AI e abbonamenti</p>
        <p class="text-navy-400 text-xs mt-1">Sessione: <span class="text-gold-400">{adminEmail}</span> · <a href="/api/auth/logout" class="underline hover:text-gold-300">esci</a></p>
      </div>
    </header>

    <section class="mb-6">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Utilizzo API</div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Analisi totali</div>
          <div class="text-3xl font-extrabold text-white mt-1">{stats.analisiTotali}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Analisi oggi</div>
          <div class="text-3xl font-extrabold text-gold-400 mt-1">{stats.analisiOggi}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Lettere generate</div>
          <div class="text-3xl font-extrabold text-white mt-1">{stats.lettereTotali}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Richieste bloccate</div>
          <div class="text-3xl font-extrabold text-amber-300 mt-1">{stats.bloccatiTotali}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Errori AI</div>
          <div class="text-3xl font-extrabold text-red-400 mt-1">{stats.erroriTotali}</div>
        </div>
      </div>
    </section>

    <section class="mb-6">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Abbonamenti PayPal</div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Abbonati attivi</div>
          <div class="text-3xl font-extrabold text-emerald-400 mt-1">{abb.attivi}</div>
        </div>
        <div class="rounded-xl border border-navy-700 bg-navy-900 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Abbonamenti totali</div>
          <div class="text-3xl font-extrabold text-white mt-1">{abb.totali}</div>
        </div>
        <div class="rounded-xl border border-gold-400/40 bg-gradient-to-br from-navy-900 to-navy-800 p-4">
          <div class="text-xs text-navy-400 uppercase tracking-widest">Ricavo totale</div>
          <div class="text-3xl font-extrabold text-gold-400 mt-1">{ricavoEuro} €</div>
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-navy-700 bg-navy-900 p-5 mb-8">
      <div class="text-sm text-navy-200 font-bold mb-4">Analisi per giorno — ultimi 7 giorni</div>
      <div class="grid grid-cols-7 gap-2 items-end" style="min-height:160px">
        {stats.perGiorno.map((g) => {
          const h = Math.round((g.analisi / maxAnalisi) * 130);
          return (
            <div class="flex flex-col items-center gap-1">
              <div class="text-[10px] text-navy-400 font-semibold">{g.analisi}</div>
              <div class="w-full rounded-t bg-gradient-to-t from-gold-400 to-amber-200" style={`height:${Math.max(h, 2)}px`} title={`${g.giorno}: ${g.analisi} analisi`}></div>
              <div class="text-[10px] text-navy-400 mt-1">{oggiBreve(g.giorno)}</div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="mb-8">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Abbonati ({abb.totali})</div>
      <div class="rounded-xl border border-navy-700 bg-navy-900 overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="text-navy-400 uppercase tracking-widest text-[10px] border-b border-navy-800">
              <th class="text-left p-3">Data</th>
              <th class="text-left p-3">Email</th>
              <th class="text-left p-3">Stato</th>
              <th class="text-left p-3">Piano</th>
              <th class="text-right p-3">Importo</th>
              <th class="text-left p-3">Scadenza</th>
              <th class="text-left p-3">PayPal Order ID</th>
            </tr>
          </thead>
          <tbody>
            {abb.records.length === 0 ? (
              <tr><td colspan="7" class="p-6 text-center text-navy-400">Nessun abbonato ancora.</td></tr>
            ) : abb.records.map((r) => {
              const attivo = new Date(r.dataScadenza) > new Date();
              const importo = ({ mensile: '2,99 €', semestrale: '7,99 €', annuale: '14,99 €' } as const)[r.piano];
              return (
                <tr class="border-b border-navy-800 last:border-0">
                  <td class="p-3 text-navy-200">{fmtSoloData(r.dataEmissione)}</td>
                  <td class="p-3 text-navy-100">{r.email}</td>
                  <td class="p-3">
                    {attivo
                      ? <span class="inline-block bg-emerald-500/15 text-emerald-300 border border-emerald-500/30 rounded px-2 py-0.5 text-[10px] font-bold uppercase">Attivo</span>
                      : <span class="inline-block bg-red-500/15 text-red-300 border border-red-500/30 rounded px-2 py-0.5 text-[10px] font-bold uppercase">Scaduto</span>
                    }
                  </td>
                  <td class="p-3 capitalize text-navy-200">{r.piano}</td>
                  <td class="p-3 text-right text-gold-300 font-bold">{importo}</td>
                  <td class="p-3 text-navy-300">{fmtSoloData(r.dataScadenza)}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">{r.paypalOrderId}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-12">
      <div class="text-xs uppercase tracking-widest text-navy-400 font-bold mb-3">Richieste API recenti (ultime {eventi.length})</div>
      <div class="rounded-xl border border-navy-700 bg-navy-900 overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="text-navy-400 uppercase tracking-widest text-[10px] border-b border-navy-800">
              <th class="text-left p-3">Timestamp</th>
              <th class="text-left p-3">Tipo</th>
              <th class="text-left p-3">Esito</th>
              <th class="text-left p-3">Errore / Warning</th>
              <th class="text-left p-3">Request ID</th>
              <th class="text-left p-3">IP</th>
              <th class="text-right p-3">ms</th>
            </tr>
          </thead>
          <tbody>
            {eventi.length === 0 ? (
              <tr><td colspan="7" class="p-6 text-center text-navy-400">Nessuna chiamata API ancora registrata.</td></tr>
            ) : eventi.map((e) => {
              const colore = e.esito === 'ok'
                ? 'bg-emerald-500/15 text-emerald-300 border-emerald-500/30'
                : e.esito === 'bloccato'
                  ? 'bg-amber-500/15 text-amber-300 border-amber-500/30'
                  : 'bg-red-500/15 text-red-300 border-red-500/30';
              return (
                <tr class="border-b border-navy-800 last:border-0">
                  <td class="p-3 text-navy-300">{fmtData(e.ts)}</td>
                  <td class="p-3 text-navy-200">{e.tipo}</td>
                  <td class="p-3">
                    <span class={`inline-block rounded px-2 py-0.5 text-[10px] font-bold uppercase border ${colore}`}>{e.esito}</span>
                  </td>
                  <td class="p-3 text-navy-300 max-w-xs truncate" title={e.errore ?? ''}>{e.errore ?? '—'}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">{e.requestId}</td>
                  <td class="p-3 text-navy-400 font-mono text-[10px]">{e.ip}</td>
                  <td class="p-3 text-right text-navy-200">{e.ms}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</BaseLayout>
