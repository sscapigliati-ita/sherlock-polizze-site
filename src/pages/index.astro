          .filter(Boolean)
          .slice(0, 2)
          .map((p) => p[0]?.toUpperCase() ?? '')
          .join('');
        return (
          <li class="bg-navy-900 border border-navy-800 rounded-xl p-5 flex flex-col hover:border-gold-400/30 transition">
            <div class="flex items-start gap-3 mb-3">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-gold-400 to-gold-600 flex items-center justify-center text-navy-900 font-extrabold text-sm">
