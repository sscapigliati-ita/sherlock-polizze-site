---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const playStoreUrl = 'https://play.google.com/store/apps/details?id=it.sherlock.polizze';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Sherlock — Detective Polizze',
    url: 'https://www.sherlockpolizze.it',
    inLanguage: 'it-IT',
    publisher: {
      '@type': 'Organization',
      name: 'Sherlock',
      logo: { '@type': 'ImageObject', url: 'https://www.sherlockpolizze.it/icon.png' },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Sherlock — Detective Polizze',
    operatingSystem: 'Android, iOS (PWA), Web',
    applicationCategory: 'FinanceApplication',
    downloadUrl: 'https://www.sherlockpolizze.it/app/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
    inLanguage: 'it-IT',
    description: 'Analizza polizze e dinieghi assicurativi. Genera bozze di reclamo PEC o IVASS.',
  },
];
---
<BaseLayout
  title="Sinistro respinto o polizza poco chiara? Sherlock controlla e prepara il reclamo"
  description="Carica polizza e lettera di diniego. Sherlock individua clausole, esclusioni e basi di reclamo PEC o IVASS. 1ª analisi gratis, nessuna carta richiesta."
  jsonLd={jsonLd}
>
  <Header slot="header" />

  <section
    aria-labelledby="caso-studio-hero"
    class="relative overflow-hidden border-b border-gold-400/40 bg-gradient-to-br from-navy-900 via-navy-950 to-navy-900"
  >
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-24 -left-24 w-72 h-72 rounded-full bg-gold-400/10 blur-3xl"></div>
      <div class="absolute -bottom-24 -right-24 w-72 h-72 rounded-full bg-red-500/10 blur-3xl"></div>
    </div>
    <div class="relative max-w-5xl mx-auto px-5 py-12 lg:py-16">
      <div class="inline-flex items-center gap-2 bg-gold-400/15 border border-gold-400/60 px-3 py-1 rounded-full text-[11px] uppercase tracking-[0.18em] text-gold-300 font-extrabold mb-5 shadow-lg shadow-gold-400/10">
        <span class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></span>
        🔎 Caso studio · vita vissuta
      </div>
      <h2 id="caso-studio-hero" class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-[1.08] tracking-tight mb-5">
        Ho fatto ricorso all'<span class="text-gold-400">Arbitro Assicurativo</span>.<br class="hidden sm:block" />
        Il dispositivo dice <span class="text-red-400">«non accoglie»</span>.
        <span class="text-white">Le motivazioni dicono altro.</span>
      </h2>
      <p class="text-lg lg:text-xl text-navy-100 leading-relaxed max-w-3xl mb-4">
        Polizza infortuni, contestazione personale. Nel dispositivo: <em>respinto</em>.
        Nelle motivazioni: la compagnia aveva torto su quasi tutto — tranne un punto
        tecnico evitabile. <strong class="text-white">Da quel ricorso è nata Sherlock</strong>:
        perché capire cosa firmiamo non può essere un privilegio di chi ha uno studio
        legale alle spalle.
      </p>
      <p class="text-sm text-navy-400 leading-relaxed max-w-3xl mb-7">
        Una storia vera, documentata, con copia dell'atto dell'Arbitro.
        Nessun caso ipotetico, nessuno screenshot di marketing: l'evento concreto
        che ha generato questo progetto.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="/storia-sherlock"
          data-track="caso_studio_hero_cta_click"
          class="inline-flex items-center justify-center gap-2 bg-gold-400 text-navy-900 font-extrabold text-base px-6 py-4 rounded-xl hover:bg-gold-300 transition shadow-xl shadow-gold-400/30"
        >
          Leggi la storia completa →
        </a>
        <a
          href="/arbitro-assicurativo"
          data-track="caso_studio_hero_guida_click"
          class="inline-flex items-center justify-center gap-2 border border-gold-400/60 text-gold-200 font-semibold text-base px-6 py-4 rounded-xl hover:bg-gold-400/10 transition"
        >
          Vai alla guida al ricorso →
        </a>
        <a
          href="#hero-app"
          data-track="caso_studio_hero_skip_click"
          class="inline-flex items-center justify-center gap-2 border border-navy-600 text-navy-100 font-semibold text-base px-6 py-4 rounded-xl hover:bg-navy-800 transition"
        >
          Vai direttamente all'app
        </a>
      </div>
    </div>
  </section>

  <section id="hero-app" class="px-5 pt-14 pb-16 max-w-6xl mx-auto">
    <div class="grid lg:grid-cols-[2fr_3fr] gap-8 items-stretch">
      <div>
        <a href="/esempio-report" data-track="hero_badge_esempio_click" class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/40 px-3 py-1 rounded-full text-xs text-emerald-300 font-semibold mb-3 hover:bg-emerald-500/20 transition">
          <span class="bg-emerald-400 text-navy-950 text-[10px] font-extrabold px-1.5 py-0.5 rounded">METODO</span>
          Guarda una simulazione di analisi
        </a>
        <div class="inline-flex items-center gap-2 bg-gold-400/10 border border-gold-400/30 px-3 py-1 rounded-full text-xs text-gold-400 font-semibold mb-5 ml-0 sm:ml-2">
          <span class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></span>
          1ª analisi gratis · Nessuna carta richiesta
        </div>
        <h1 class="text-4xl lg:text-5xl xl:text-6xl font-extrabold text-white tracking-tight leading-[1.05] mb-5">
          La compagnia ti ha detto <span class="text-red-400">no</span>?<br />
          <span class="text-gold-400">Prima di arrenderti</span>, fai leggere la polizza a Sherlock.
        </h1>
        <p class="text-lg text-navy-100 leading-relaxed mb-6">
          <strong class="text-white">Hai ricevuto un rifiuto dalla compagnia?</strong><br />
          Carica il testo del diniego o la polizza: Sherlock ti aiuta a capire
          <strong class="text-white">quali punti verificare</strong>.
        </p>
        <div class="grid sm:grid-cols-3 gap-3">
          <a
            href={playStoreUrl}
            target="_blank"
            rel="noopener"
            data-track="hero_cta_polizza_click"
            class="bg-gold-400 text-navy-900 font-bold text-base px-4 py-4 rounded-xl hover:bg-gold-300 transition shadow-lg shadow-gold-400/20 text-center"
          >
            Analizza una polizza
          </a>
          <a
            href={playStoreUrl}
            target="_blank"
            rel="noopener"
            data-track="hero_cta_diniego_click"
            class="bg-red-500/15 border border-red-500/40 text-red-100 font-bold text-base px-4 py-4 rounded-xl hover:bg-red-500/25 transition text-center"
          >
            Analizza un diniego
          </a>
          <a
            href="/esempio-report"
            data-track="hero_cta_esempio_click"
            class="border border-navy-600 text-navy-100 font-semibold text-base px-4 py-4 rounded-xl hover:bg-navy-800 transition text-center"
          >
            Guarda esempio report
          </a>
        </div>
        <p class="text-sm text-navy-400 mt-5 leading-relaxed">
          Sherlock individua garanzie, esclusioni, franchigie e clausole contestabili.
          Se serve, prepara una bozza di <strong class="text-white">reclamo PEC o esposto IVASS</strong>
          con i riferimenti normativi giusti.
        </p>
      </div>

      <div class="flex flex-col gap-5 h-full">
      <div class="bg-gradient-to-br from-navy-800 to-navy-900 border border-navy-700 rounded-2xl p-6 shadow-2xl">
        <div class="text-xs uppercase tracking-widest text-navy-400 mb-3">Esempio di report Sherlock</div>
        <div class="space-y-3 text-sm">
          <div class="flex items-center justify-between p-3 rounded-lg bg-red-500/10 border border-red-500/30">
            <span class="text-navy-200">Rischio complessivo</span>
            <span class="font-bold text-red-300 uppercase tracking-wider">Alto</span>
          </div>
          <div class="flex items-center justify-between p-3 rounded-lg bg-amber-500/10 border border-amber-500/30">
            <span class="text-navy-200">Clausole critiche trovate</span>
            <span class="font-bold text-amber-300">4</span>
          </div>
          <div class="flex items-center justify-between p-3 rounded-lg bg-amber-500/10 border border-amber-500/30">
            <span class="text-navy-200">Franchigie / scoperti</span>
            <span class="font-bold text-amber-300">2</span>
          </div>
          <div class="flex items-center justify-between p-3 rounded-lg bg-navy-950 border border-navy-700">
            <span class="text-navy-200">Azione consigliata</span>
            <span class="font-bold text-white">Reclamo</span>
          </div>
          <div class="flex items-center justify-between p-3 rounded-lg bg-emerald-500/10 border border-emerald-500/30">
            <span class="text-navy-200">Lettera pronta</span>
            <span class="font-bold text-emerald-300">Sì</span>
          </div>
        </div>
        <div class="mt-5 pt-5 border-t border-navy-700">
          <div class="text-xs uppercase tracking-widest text-navy-400 mb-2">Tipi di polizze analizzate</div>
          <div class="flex flex-wrap gap-2 text-xs">
            {['RC auto','Casa','Vita','Salute','Infortuni','RC professionale','Viaggio','Multirischi'].map(t => (
              <span class="bg-navy-800 text-navy-200 px-2.5 py-1 rounded">{t}</span>
            ))}
          </div>
        </div>
      </div>
        <div class="flex-1 min-h-0 relative">
          <img
            src="/logo-sherlock.png"
            alt="Sherlock"
            width="512"
            height="900"
            class="absolute inset-0 m-auto max-h-full max-w-full w-auto h-auto object-contain rounded-xl shadow-2xl shadow-black/60 ring-1 ring-gold-400/20"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <a
        href="/esempio-report"
        data-track="hero_cta_esempio_click"
        class="text-sm text-navy-400 hover:text-gold-300 underline underline-offset-4 transition"
      >
        Scopri come viene costruito il report →
      </a>
      <p class="text-xs text-navy-500">
        Disponibile su Web, Android e iPhone (installabile come app) · Pagamento PayPal · Nessun rinnovo automatico
      </p>
    </div>
  </section>

  <section class="bg-navy-900 border-y border-navy-800 px-5 py-16">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-white text-center mb-3">Cosa vuoi fare oggi?</h2>
      <p class="text-center text-navy-400 mb-12">Scegli il caso più vicino al tuo. Sherlock parte da lì.</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        <a href="/sinistro-respinto" data-track="path_card_sinistro_click" class="block bg-navy-950 border border-navy-800 rounded-xl p-6 hover:border-gold-400/40 hover:shadow-xl transition group">
          <div class="text-3xl mb-3">📄</div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-gold-300 transition">Mi hanno respinto un sinistro</h3>
          <p class="text-navy-300 text-sm leading-relaxed mb-4">
            Carica diniego e polizza. Sherlock cerca clausole contestabili e prepara il reclamo.
          </p>
          <span class="inline-block text-sm font-bold text-gold-400 group-hover:text-gold-300">Inizia gratis →</span>
        </a>
        <a href="/app/" data-track="path_card_capisci_click" class="block bg-navy-950 border border-navy-800 rounded-xl p-6 hover:border-gold-400/40 hover:shadow-xl transition group">
          <div class="text-3xl mb-3">🔍</div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-gold-300 transition">Voglio capire una polizza prima di firmare</h3>
          <p class="text-navy-300 text-sm leading-relaxed mb-4">
            Sherlock evidenzia garanzie, esclusioni, franchigie e scoperti in linguaggio chiaro.
          </p>
          <span class="inline-block text-sm font-bold text-gold-400 group-hover:text-gold-300">Inizia gratis →</span>
        </a>
        <a href="/esempio-report" data-track="path_card_esempio_click" class="relative block bg-navy-950 border border-emerald-500/40 rounded-xl p-6 hover:border-emerald-400 hover:shadow-xl transition group">
          <span class="absolute top-3 right-3 bg-emerald-400 text-navy-950 text-[10px] font-extrabold uppercase tracking-wider px-2 py-0.5 rounded">Demo</span>
          <div class="text-3xl mb-3">📋</div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-emerald-300 transition">Voglio vedere il metodo prima di iniziare</h3>
          <p class="text-navy-300 text-sm leading-relaxed mb-4">
            Esplora una simulazione con clausole rilevanti, informazioni mancanti e punti da verificare.
          </p>
          <span class="inline-block text-sm font-bold text-emerald-400 group-hover:text-emerald-300">Guarda la simulazione →</span>
        </a>
        <a href="/reclamo-ivass" data-track="path_card_ivass_click" class="block bg-navy-950 border border-navy-800 rounded-xl p-6 hover:border-gold-400/40 hover:shadow-xl transition group">
          <div class="text-3xl mb-3">⚖️</div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-gold-300 transition">Devo scrivere a compagnia o IVASS</h3>
          <p class="text-navy-300 text-sm leading-relaxed mb-4">
            Genera una bozza strutturata di PEC, reclamo formale o esposto IVASS.
          </p>
          <span class="inline-block text-sm font-bold text-gold-400 group-hover:text-gold-300">Inizia gratis →</span>
        </a>
      </div>

      <div class="mt-8 bg-navy-950 border border-navy-800 rounded-xl px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-2 text-sm">
        <div class="text-xs uppercase tracking-widest text-navy-500 font-bold flex-shrink-0">
          Il percorso completo
        </div>
        <div class="flex flex-wrap items-center gap-2 text-navy-200">
          <a href="/sinistro-respinto" class="hover:text-gold-300 font-semibold">Sinistro respinto</a>
          <span class="text-navy-600">→</span>
          <a href="/reclamo-ivass" class="hover:text-gold-300 font-semibold">Reclamo &amp; IVASS</a>
          <span class="text-navy-600">→</span>
          <a href="/arbitro-assicurativo" class="hover:text-gold-300 font-semibold">Ricorso all'Arbitro</a>
        </div>
      </div>
    </div>
  </section>

  <section id="come-funziona" class="px-5 py-16 max-w-6xl mx-auto">
    <h2 class="text-3xl lg:text-4xl font-extrabold text-white text-center mb-3">Come funziona</h2>
    <p class="text-center text-navy-400 mb-12">Tre passi. Nessuna competenza tecnica richiesta.</p>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-navy-900 border border-navy-800 rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-gold-400/15 text-gold-400 font-extrabold text-xl flex items-center justify-center mb-4">1</div>
        <h3 class="text-xl font-bold text-white mb-2">Carica polizza (e diniego)</h3>
        <p class="text-navy-300 text-sm leading-relaxed">
          Fotografa il documento o carica il PDF dal browser, da Android o dalla PWA su iPhone.
          Se hai ricevuto una lettera di diniego, caricala anche.
        </p>
      </div>
      <div class="bg-navy-900 border border-navy-800 rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-gold-400/15 text-gold-400 font-extrabold text-xl flex items-center justify-center mb-4">2</div>
        <h3 class="text-xl font-bold text-white mb-2">Sherlock analizza</h3>
        <p class="text-navy-300 text-sm leading-relaxed">
          Estrae garanzie, esclusioni, franchigie, scoperti, termini di decadenza e clausole
          contestabili. In pochi secondi.
        </p>
      </div>
      <div class="bg-navy-900 border border-navy-800 rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-gold-400/15 text-gold-400 font-extrabold text-xl flex items-center justify-center mb-4">3</div>
        <h3 class="text-xl font-bold text-white mb-2">Agisci con consapevolezza</h3>
        <p class="text-navy-300 text-sm leading-relaxed">
          Ricevi un report dettagliato e, se serve, una bozza di reclamo PEC, esposto IVASS o
          diffida — con riferimenti normativi pertinenti, da rivedere prima dell'invio.
        </p>
      </div>
    </div>
    <div class="text-center mt-10">
      <div class="text-sm text-navy-400 mb-3">Vuoi vedere cosa produce Sherlock prima di provarlo?</div>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/esempio-report" class="inline-block border border-navy-700 text-navy-100 font-semibold px-5 py-2.5 rounded-lg hover:bg-navy-900 transition">
          Vedi esempio report
        </a>
        <a href="/esempio-lettera" class="inline-block border border-navy-700 text-navy-100 font-semibold px-5 py-2.5 rounded-lg hover:bg-navy-900 transition">
          Vedi esempio reclamo IVASS
        </a>
      </div>
    </div>
  </section>

  {/* Riquadro storia — origine del nome Sherlock */}
  <section class="px-5 py-16 max-w-6xl mx-auto">
    <div class="relative overflow-hidden rounded-3xl border border-gold-400/30 bg-gradient-to-br from-navy-900 via-navy-950 to-navy-900 shadow-2xl shadow-black/40">
      {/* Glow decorativo di sfondo */}
      <div aria-hidden="true" class="pointer-events-none absolute -top-32 -right-32 w-96 h-96 rounded-full bg-gold-400/10 blur-3xl"></div>
      <div aria-hidden="true" class="pointer-events-none absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-emerald-400/5 blur-3xl"></div>

      <div class="relative grid md:grid-cols-5 gap-0 items-stretch">
        {/* Foto */}
        <div class="md:col-span-2 relative min-h-[280px] md:min-h-[420px]">
          <img
            src="/sherlock-cane.jpg"
            alt="Sherlock, il nostro cane trovato in una scatola davanti al cancello"
            width="1200"
            height="800"
            fetchpriority="low"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
          />
          {/* Sfumatura verso destra per fondersi con il testo su desktop */}
          <div aria-hidden="true" class="hidden md:block absolute inset-y-0 right-0 w-24 bg-gradient-to-r from-transparent to-navy-900/95"></div>
          {/* Sfumatura verso il basso su mobile */}
          <div aria-hidden="true" class="md:hidden absolute inset-x-0 bottom-0 h-20 bg-gradient-to-b from-transparent to-navy-900"></div>
        </div>

        {/* Storia */}
        <div class="md:col-span-3 p-7 md:p-10 flex flex-col justify-center">
          <div class="inline-flex items-center gap-2 self-start bg-gold-400/10 border border-gold-400/40 px-3 py-1 rounded-full text-xs text-gold-300 font-semibold mb-5">
            <span aria-hidden="true">🐾</span>
            La storia dietro il nome
          </div>

          <h2 class="text-3xl lg:text-4xl font-extrabold text-white tracking-tight leading-tight mb-4">
            Sherlock non è solo un detective.<br />
            <span class="text-gold-400">È anche il nostro cane.</span>
          </h2>

          <div class="space-y-3 text-navy-200 leading-relaxed">
            <p>
              Una mattina l'abbiamo trovato in una scatola di cartone, fuori dal cancello.
              Piccolo, spaventato, con quegli occhi che chiedevano solo una cosa: fidati di me,
              io mi fiderò di te. L'abbiamo chiamato <strong class="text-white">Sherlock</strong>
              — come il detective — perché aveva subito quello sguardo che <em>vede tutto</em>.
            </p>
            <p>
              Da allora non ci ha più lasciati soli. È stato con noi <strong class="text-white">nei momenti difficili</strong>,
              nelle notti storte, nei giorni in cui non c'era niente da dire. Non ha mai chiesto niente
              in cambio — solo di esserci. È il suo modo di amare: <strong class="text-white">viscerale, totale,
              senza calcoli</strong>. Sta lì, ti guarda, e tu sai che <em>non sei solo</em>.
            </p>
            <p>
              E poi c'è il suo talento: Sherlock è un <strong class="text-white">cercatore di tartufi</strong>.
              Naso a terra, passo dopo passo, tira fuori dai boschi quello che nessuno vedrebbe — cose preziose,
              sepolte sotto la terra, coperte di foglie. Non le trova per fortuna. Le <em>fiuta</em>.
            </p>
            <p class="text-navy-100">
              Abbiamo dato il suo nome a questa app per quello: un'app che scava nei
              <strong class="text-gold-300">meandri della polizza</strong>, fiuta i cavilli e le clausole
              che le compagnie nascondono ad arte tra le righe, e riporta alla luce
              <strong class="text-white">quello che loro sperano tu non veda mai</strong>. Come Sherlock col tartufo:
              ti sta accanto, cerca, e non molla finché non trova.
            </p>
          </div>

          <div class="mt-7 flex flex-col sm:flex-row gap-3">
            <a
              href="/app/"
              data-track="storia_cane_cta_prova_click"
              class="inline-flex items-center justify-center gap-2 bg-gold-400 text-navy-900 font-bold px-6 py-3 rounded-lg hover:bg-gold-300 transition shadow-lg shadow-gold-400/20"
            >
              Prova Sherlock gratis
              <span aria-hidden="true">→</span>
            </a>
            <a
              href="/storia-sherlock"
              data-track="storia_cane_cta_leggi_click"
              class="inline-flex items-center justify-center gap-2 border border-navy-600 text-navy-100 font-semibold px-6 py-3 rounded-lg hover:bg-navy-800 transition"
            >
              Leggi la storia completa
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-navy-900 border-y border-navy-800 px-5 py-16">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-white text-center mb-3">5 frasi della polizza da controllare subito</h2>
      <p class="text-center text-navy-400 mb-12">Le formule che le compagnie usano per limitare i rimborsi. Spesso si nascondono nella pagina 12.</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { f: 'salvo quanto previsto dalle esclusioni', r: 'rimanda a un elenco di casi non coperti — spesso più lungo delle garanzie.' },
          { f: 'entro e non oltre', r: 'fissa un termine perentorio: superato, perdi il diritto.' },
