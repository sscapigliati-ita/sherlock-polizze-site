# ============================================================
# BACKEND AI (analisi polizze + generazione lettere)
# ============================================================

# Chiave API Anthropic - obbligatoria
# Inseriscila su Vercel: Project Settings → Environment Variables
ANTHROPIC_API_KEY=

# Modello Claude da usare (opzionale, default claude-sonnet-4-6)
# Alternative: claude-opus-4-8 (più costoso, qualità top), claude-haiku-4-5-20251001 (più economico)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Lista codici Pro validi separati da virgola (opzionale)
# Se vuoto E nessun KV configurato: il backend valida qualunque codice ben formato (modalità dev)
# Se vuoto MA KV configurato: solo codici emessi via PayPal sono validi (modalità produzione)
PRO_CODES=

# ============================================================
# PAYPAL (Fase 2 — flusso di pagamento abbonamenti)
# ============================================================

# Credenziali PayPal REST API (ottieni da developer.paypal.com → My Apps & Credentials)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# Modalità: "live" per produzione, "sandbox" per test (default: live)
PAYPAL_MODE=live

# ============================================================
# MAIL (Resend per inviare il codice Pro all'utente)
# ============================================================

# API key Resend (gratis fino a 100 mail/giorno, https://resend.com)
RESEND_API_KEY=

# Mittente (deve essere verificato su Resend, default usa quello di test Resend)
MAIL_FROM="Sherlock <noreply@sherlockpolizze.it>"

# Reply-to per supporto utente
MAIL_REPLY_TO=scaplab@sherlockpolizze.it

# ============================================================
# VERCEL KV (storage codici Pro emessi - opzionale ma raccomandato per produzione)
# ============================================================

# Queste variabili sono iniettate AUTOMATICAMENTE da Vercel quando colleghi un KV al progetto.
# Storage → Create Database → KV → Connect to Project.
# Se non collegato, i codici emessi sono salvati solo in-memory (persi al riavvio function).
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# ============================================================
# FIREBASE WEB ANALYTICS (tracking lato browser via SDK web)
# ============================================================

# Config della Web App Firebase del progetto sherlock-6f88c.
# Dove prenderli: Firebase Console → ⚙️ Impostazioni progetto → "Le tue app" →
# Web app (icona </>) → "SDK setup and configuration" → seleziona "Config".
# I valori sono PUBBLICI per design (vengono inlinati nell'HTML al build): vanno bene in repo.
# ATTENZIONE: NON usare i valori-segnaposto (es. "apiKey":"apiKey") — il build li accetta
# come stringhe valide ma Firebase fallisce silenziosamente e nessun evento arriva.
# In Astro `PUBLIC_*` viene inlinato al BUILD: dopo aver settato/modificato su Vercel
# serve un NUOVO deploy perché le pagine prendano i nuovi valori.
PUBLIC_FIREBASE_API_KEY=AIzaSy...
PUBLIC_FIREBASE_AUTH_DOMAIN=sherlock-6f88c.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=sherlock-6f88c
PUBLIC_FIREBASE_STORAGE_BUCKET=sherlock-6f88c.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=144000904036
PUBLIC_FIREBASE_APP_ID=1:144000904036:web:xxxxxxxxxxxxxxxxxxxxxx
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# GA4 MEASUREMENT PROTOCOL (tracking server-side da serverless functions)
# ============================================================

# Secret usato da src/lib/ga4.ts per inviare eventi server-side (es. purchase_success
# dopo la cattura del pagamento PayPal) direttamente a GA4 via Measurement Protocol.
# Dove prenderlo: Google Analytics → ⚙️ Admin → Data Streams → seleziona lo stream Web
# → "Measurement Protocol API secrets" → Create → copia il "Secret value".
# Senza questa var (o senza PUBLIC_FIREBASE_MEASUREMENT_ID) ga4TrackServer è no-op.
# Marca questa env var come SENSITIVE su Vercel.
GA4_API_SECRET=

# ============================================================
# GA4 gtag.js CLIENT-SIDE (property dedicata a Google Ads / Conversions)
# ============================================================

# Measurement ID GA4 usato da BaseLayout.astro per caricare gtag.js con Consent Mode v2
# ed emettere gli eventi di conversione: click_play_store, start_analysis, click_abbonati,
# contact_or_report. Questa è una property SEPARATA da PUBLIC_FIREBASE_MEASUREMENT_ID
# (Firebase Analytics continua a girare in parallelo con la sua nomenclatura storica).
# Dove prenderlo: Google Analytics → ⚙️ Admin → Data Streams → Web → copia "Measurement ID".
# Default hardcoded in BaseLayout.astro = G-21MQHMK771 (stream "Sherlock Polizze Web",
# stream ID 15187336886). Impostare esplicitamente su Vercel → Production Env Vars per
# override o per essere robusti a modifiche future del default. Il tag è attivo solo su
# hostname www.sherlockpolizze.it e in build di produzione (astro dev e preview
# *.vercel.app sono esclusi).
PUBLIC_GA4_ID=G-21MQHMK771

# Stream server-side separati (raccomandati; nessun valore di fallback inventato)
GA4_WEB_MEASUREMENT_ID=
GA4_WEB_API_SECRET=
GA4_FIREBASE_MEASUREMENT_ID=
GA4_FIREBASE_API_SECRET=

# ============================================================
# ADMIN GOOGLE OAUTH
# ============================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generare un valore casuale lungo nel gestore segreti dell'ambiente.
SESSION_SECRET=

# Token Search Console pubblico, se utilizzato.
PUBLIC_GOOGLE_SITE_VERIFICATION=

# ============================================================
# GOOGLE PLAY
# ============================================================

# JSON service account codificato base64; valore segreto server-side.
GOOGLE_SERVICE_ACCOUNT_B64=
PLAY_APP_PACKAGE_NAME=it.sherlock.polizze
PLAY_PACKAGE_NAME=it.sherlock.polizze
PLAY_REPORTS_BUCKET=
